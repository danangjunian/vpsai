}

function getStokMotor_(payload) {
  const sh = getSheetByToken_(SHEETS.STOK_MOTOR);
  if (!sh) throw appError_("sheet_not_found");

  const lastRow = sh.getLastRow();
  if (lastRow < 2) return [];

  const count = lastRow - 1;
  const raw = sh.getRange(2, 1, count, 13).getValues();
  const disp = sh.getRange(2, 1, count, 13).getDisplayValues();

  const qNo = normalizeNo_(pickAny_(payload, ["no", "nomor", "id"]));
  const qName = normalizeSearch_(pickAny_(payload, ["nama_motor", "nama", "keyword", "q"]));
  const qTokens = qName ? qName.split(" ").filter(Boolean) : [];
  const rawStatus = pickAny_(payload, ["status"]);
  const hasExplicitStatus = String(rawStatus === undefined || rawStatus === null ? "" : rawStatus).trim() !== "";
  const includeSold = toBoolValue_(pickAny_(payload, ["include_sold", "show_sold"]));
  const statusFilter = hasExplicitStatus
    ? normalizeStatusFilter_(rawStatus)
    : (includeSold ? "all" : "belum_terjual");
  const limit = normalizeLimit_(pickAny_(payload, ["limit"]), 200, 1000);

  const rows = [];
  for (let i = 0; i < raw.length; i++) {
    const rowRaw = raw[i];
    const rowDisp = disp[i];
    const no = normalizeNo_(rowDisp[0]);
    if (!no) continue;

    const namaMotor = String(rowDisp[1] || "").trim();
    const tahun = String(rowDisp[2] || "").trim();
    const plat = String(rowDisp[3] || "").trim();
    if (!namaMotor && !tahun && !plat) continue;

    if (qNo && qNo !== no) continue;

    if (qTokens.length) {
      const nameNorm = normalizeSearch_(rowDisp[1]);
      let ok = true;
      for (let t = 0; t < qTokens.length; t++) {
        if (nameNorm.indexOf(qTokens[t]) === -1) {
          ok = false;
          break;
        }
      }
      if (!ok) continue;
    }

    const sold = isSoldRow_(rowRaw, rowDisp);
    if (statusFilter === "terjual" && !sold) continue;
    if (statusFilter === "belum_terjual" && sold) continue;

    rows.push({
      row: i + 2,
      no: no,
      nama_motor: namaMotor,
      tahun: tahun,
      plat: plat,
      surat_surat: String(rowDisp[4] || "").trim(),
      tahun_plat: String(rowDisp[5] || "").trim(),
      pajak: String(rowDisp[6] || "").trim(),
      harga_jual: numberOrDisplay_(rowRaw[7], rowDisp[7]),
      harga_laku: numberOrDisplay_(rowRaw[8], rowDisp[8]),
      tgl_terjual: normalizeDateCell_(rowRaw[9], rowDisp[9]),
      harga_beli: numberOrDisplay_(rowRaw[11], rowDisp[11]),
      status: sold ? "terjual" : "belum_terjual"
    });

    if (rows.length >= limit) break;
  }

  return rows;
}

function insertStokMotor_(payload) {
  const sh = getSheetByToken_(SHEETS.STOK_MOTOR);
  if (!sh) throw appError_("sheet_not_found");

  const namaMotor = pickString_(payload, ["nama_motor", "nama"]);
  if (!namaMotor) throw appError_("nama_motor_required");

  const tahun = pickString_(payload, ["tahun"]);
  const plat = pickString_(payload, ["plat"]).toUpperCase();
  const suratSurat = pickString_(payload, ["surat_surat", "surat"]);
  const tahunPlat = pickString_(payload, ["tahun_plat", "tahunplat"]);
  const pajak = pickString_(payload, ["pajak"]);
  const hargaJual = pickNumber_(payload, ["harga_jual", "jual"]);
  const hargaLaku = pickNumber_(payload, ["harga_laku", "laku"]);
  const hargaBeli = pickNumber_(payload, ["harga_beli", "beli"]);
  let tglTerjual = pickDate_(payload, ["tgl_terjual", "tanggal_terjual"]);
  if (!tglTerjual && isPositiveNumber_(hargaLaku)) tglTerjual = new Date();

  const row = findFirstEmptyRow_(sh, 2, 2);
  const status = resolveStatus_(pickAny_(payload, ["status"]), hargaLaku, tglTerjual);

  // Dilarang mengubah/mengisi nomor kolom A dari API.
  sh.getRange(row, 2).setValue(namaMotor);
  sh.getRange(row, 3).setValue(tahun);
  sh.getRange(row, 4).setValue(plat);
  sh.getRange(row, 5).setValue(suratSurat);
  sh.getRange(row, 6).setValue(tahunPlat);
  sh.getRange(row, 7).setValue(pajak);
  sh.getRange(row, 8).setValue(hargaJual === null ? "" : hargaJual);
  sh.getRange(row, 9).setValue(hargaLaku === null ? "" : hargaLaku);
  sh.getRange(row, 10).setValue(tglTerjual || "");
  sh.getRange(row, 12).setValue(hargaBeli === null ? "" : hargaBeli);
  sh.getRange(row, 13).setValue(status);

  SpreadsheetApp.flush();
  const no = normalizeNo_(sh.getRange(row, 1).getDisplayValue());
  return { row: row, no: no };
}

function updateStokMotor_(payload) {
  const sh = getSheetByToken_(SHEETS.STOK_MOTOR);
  if (!sh) throw appError_("sheet_not_found");

  const row = resolveRow_(sh, payload, 1);
  if (!row) throw appError_("data_not_found");

  const hasNama = hasAnyKey_(payload, ["nama_motor", "nama"]);
  const hasTahun = hasAnyKey_(payload, ["tahun"]);
  const hasPlat = hasAnyKey_(payload, ["plat"]);
  const hasSurat = hasAnyKey_(payload, ["surat_surat", "surat"]);
  const hasTahunPlat = hasAnyKey_(payload, ["tahun_plat", "tahunplat"]);
  const hasPajak = hasAnyKey_(payload, ["pajak"]);
  const hasHargaJual = hasAnyKey_(payload, ["harga_jual", "jual"]);
  const hasHargaLaku = hasAnyKey_(payload, ["harga_laku", "laku"]);
  const hasHargaBeli = hasAnyKey_(payload, ["harga_beli", "beli"]);
  const hasTglTerjual = hasAnyKey_(payload, ["tgl_terjual", "tanggal_terjual"]);
  const hasStatus = hasAnyKey_(payload, ["status"]);

  if (!(hasNama || hasTahun || hasPlat || hasSurat || hasTahunPlat || hasPajak || hasHargaJual || hasHargaLaku || hasHargaBeli || hasTglTerjual || hasStatus)) {
    throw appError_("empty_update");
  }

  if (hasNama) sh.getRange(row, 2).setValue(pickString_(payload, ["nama_motor", "nama"]));
  if (hasTahun) sh.getRange(row, 3).setValue(pickString_(payload, ["tahun"]));
  if (hasPlat) sh.getRange(row, 4).setValue(pickString_(payload, ["plat"]).toUpperCase());
  if (hasSurat) sh.getRange(row, 5).setValue(pickString_(payload, ["surat_surat", "surat"]));
  if (hasTahunPlat) sh.getRange(row, 6).setValue(pickString_(payload, ["tahun_plat", "tahunplat"]));
  if (hasPajak) sh.getRange(row, 7).setValue(pickString_(payload, ["pajak"]));

  if (hasHargaJual) {
    const hargaJual = pickNumber_(payload, ["harga_jual", "jual"]);
    sh.getRange(row, 8).setValue(hargaJual === null ? "" : hargaJual);
  }

  if (hasHargaLaku) {
    const hargaLaku = pickNumber_(payload, ["harga_laku", "laku"]);
    sh.getRange(row, 9).setValue(hargaLaku === null ? "" : hargaLaku);

    if (!hasTglTerjual && isPositiveNumber_(hargaLaku)) {
      const existingTgl = sh.getRange(row, 10).getValue();
      if (!isFilledValue_(existingTgl)) sh.getRange(row, 10).setValue(new Date());
    }
  }

  if (hasTglTerjual) {
    const tglTerjual = pickDate_(payload, ["tgl_terjual", "tanggal_terjual"]);
    sh.getRange(row, 10).setValue(tglTerjual || "");
  }

  if (hasHargaBeli) {
    const hargaBeli = pickNumber_(payload, ["harga_beli", "beli"]);
    sh.getRange(row, 12).setValue(hargaBeli === null ? "" : hargaBeli);
  }

  if (hasStatus || hasHargaLaku || hasTglTerjual) {
    const currentHargaLaku = sh.getRange(row, 9).getValue();
    const currentTglTerjual = sh.getRange(row, 10).getValue();
    const status = resolveStatus_(pickAny_(payload, ["status"]), currentHargaLaku, currentTglTerjual);
    sh.getRange(row, 13).setValue(status);
  }

  const no = normalizeNo_(sh.getRange(row, 1).getDisplayValue());
  return { row: row, no: no };
}

function deleteStokMotor_(payload) {
  const sh = getSheetByToken_(SHEETS.STOK_MOTOR);
  if (!sh) throw appError_("sheet_not_found");

  const row = resolveRow_(sh, payload, 1);
  if (!row) throw appError_("data_not_found");
  assertDataRow_(row);

  const no = normalizeNo_(sh.getRange(row, 1).getDisplayValue());
  // STOK MOTOR: protect column A (NO) and column K; clear content only on allowed columns.
  clearRowContentByPolicy_(SHEETS.STOK_MOTOR, sh, row, [2, 3, 4, 5, 6, 7, 8, 9, 10, 12, 13]);
  return { row: row, no: no };
}

function getPengeluaran_(payload) {
  const sh = getSheetByToken_(SHEETS.PENGELUARAN_HARIAN);
  if (!sh) throw appError_("sheet_not_found");

  const map = detectExpenseColumns_(sh);
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return [];

  const width = Math.max(sh.getLastColumn(), map.noCol, map.dateCol, map.descCol, map.amountCol);
  const count = lastRow - 1;
  const raw = sh.getRange(2, 1, count, width).getValues();
  const disp = sh.getRange(2, 1, count, width).getDisplayValues();

  const qNo = normalizeNo_(pickAny_(payload, ["no", "nomor", "id"]));
  const qDate = parseDateValue_(pickAny_(payload, ["tanggal", "tgl", "date"]));
  const qDateFrom = parseDateValue_(pickAny_(payload, ["date_from", "start_date", "from"]));
  const qDateTo = parseDateValue_(pickAny_(payload, ["date_to", "end_date", "to"]));
  const limit = normalizeLimit_(pickAny_(payload, ["limit"]), 200, 1000);

  const out = [];
  for (let i = 0; i < raw.length; i++) {
    const no = normalizeNo_(disp[i][map.noCol - 1]);
    if (!no) continue;
    if (qNo && qNo !== no) continue;

    const tgl = parseDateCell_(raw[i][map.dateCol - 1], disp[i][map.dateCol - 1]);
    if (qDate && (!tgl || stripTime_(tgl).getTime() !== stripTime_(qDate).getTime())) continue;
    if (qDateFrom && (!tgl || stripTime_(tgl).getTime() < stripTime_(qDateFrom).getTime())) continue;
    if (qDateTo && (!tgl || stripTime_(tgl).getTime() > stripTime_(qDateTo).getTime())) continue;

    out.push({
      row: i + 2,
      no: no,
      tanggal: tgl ? formatDateIso_(tgl) : String(disp[i][map.dateCol - 1] || "").trim(),
      keterangan: String(disp[i][map.descCol - 1] || "").trim(),
      total_pengeluaran: parseNumberValue_(raw[i][map.amountCol - 1]) || 0
    });

    if (out.length >= limit) break;
  }

  return out;
}

function insertPengeluaran_(payload) {
  const sh = getSheetByToken_(SHEETS.PENGELUARAN_HARIAN);
  if (!sh) throw appError_("sheet_not_found");

  const map = detectExpenseColumns_(sh);
  const keterangan = pickString_(payload, ["keterangan", "catatan", "deskripsi", "detail"]);
  const total = pickNumber_(payload, ["total_pengeluaran", "nominal", "jumlah", "biaya", "total"]);
  const tanggal = pickDate_(payload, ["tanggal", "tgl", "date"]) || new Date();

  if (!keterangan) throw appError_("keterangan_required");
  if (!isPositiveNumber_(total)) throw appError_("total_pengeluaran_invalid");

  const row = findFirstEmptyRow_(sh, 2, map.amountCol);
  if (map.noCol > 1) {
    const existingNo = normalizeNo_(sh.getRange(row, map.noCol).getDisplayValue());
    if (!existingNo) sh.getRange(row, map.noCol).setValue(nextNumericNoByColumn_(sh, map.noCol));
  }

  sh.getRange(row, map.dateCol).setValue(tanggal);
  sh.getRange(row, map.descCol).setValue(keterangan);
  sh.getRange(row, map.amountCol).setValue(total);

  return {
    row: row,
    no: map.noCol > 0 ? normalizeNo_(sh.getRange(row, map.noCol).getDisplayValue()) : ""
  };
}

function updatePengeluaran_(payload) {
  const sh = getSheetByToken_(SHEETS.PENGELUARAN_HARIAN);
  if (!sh) throw appError_("sheet_not_found");

  const map = detectExpenseColumns_(sh);
  const row = resolveRow_(sh, payload, map.noCol);
  if (!row) throw appError_("data_not_found");

  const hasKet = hasAnyKey_(payload, ["keterangan", "catatan", "deskripsi", "detail"]);
  const hasTotal = hasAnyKey_(payload, ["total_pengeluaran", "nominal", "jumlah", "biaya", "total"]);
  const hasTgl = hasAnyKey_(payload, ["tanggal", "tgl", "date"]);

  if (!(hasKet || hasTotal || hasTgl)) throw appError_("empty_update");

  if (hasKet) sh.getRange(row, map.descCol).setValue(pickString_(payload, ["keterangan", "catatan", "deskripsi", "detail"]));
  if (hasTotal) {
    const total = pickNumber_(payload, ["total_pengeluaran", "nominal", "jumlah", "biaya", "total"]);
    if (!isPositiveNumber_(total)) throw appError_("total_pengeluaran_invalid");
    sh.getRange(row, map.amountCol).setValue(total);
  }
  if (hasTgl) {
    const tanggal = pickDate_(payload, ["tanggal", "tgl", "date"]) || new Date();
    sh.getRange(row, map.dateCol).setValue(tanggal);
  }

  const no = map.noCol > 0 ? normalizeNo_(sh.getRange(row, map.noCol).getDisplayValue()) : "";
  return { row: row, no: no };
}

function deletePengeluaran_(payload) {
  const sh = getSheetByToken_(SHEETS.PENGELUARAN_HARIAN);
  if (!sh) throw appError_("sheet_not_found");

  const map = detectExpenseColumns_(sh);
  const row = resolveRow_(sh, payload, map.noCol);
  if (!row) throw appError_("data_not_found");
  assertDataRow_(row);

  const no = map.noCol > 0 ? normalizeNo_(sh.getRange(row, map.noCol).getDisplayValue()) : "";
  // PENGELUARAN HARIAN: clear content only on A, B, C.
  clearRowContentByPolicy_(SHEETS.PENGELUARAN_HARIAN, sh, row, [1, 2, 3]);
  return { row: row, no: no };
}

function getTotalAset_(payload) {
  const sh = getSheetByToken_(SHEETS.TOTAL_ASET);
  if (!sh) throw appError_("sheet_not_found");

  const label = normalizeSearch_(pickAny_(payload, ["metric_label", "label", "metric", "nama_metric"]));
  if (label) {
    const value = findMetricValueByLabel_(sh, label);
    return [{ metric_label: label, value: value }];
  }

  const lastRow = sh.getLastRow();
  const lastCol = sh.getLastColumn();
  if (lastRow < 1 || lastCol < 1) return [];

  const disp = sh.getRange(1, 1, lastRow, lastCol).getDisplayValues();
  const out = [];
  for (let r = 0; r < disp.length; r++) {
    let hasValue = false;
    for (let c = 0; c < disp[r].length; c++) {
      if (String(disp[r][c] || "").trim()) {
        hasValue = true;
        break;
      }
    }
    if (!hasValue) continue;
    out.push({ row: r + 1, values: disp[r] });
  }

  return out;
}

function insertTotalAset_(payload) {
  const sh = getSheetByToken_(SHEETS.TOTAL_ASET);
  if (!sh) throw appError_("sheet_not_found");

  const values = Array.isArray(payload.values) ? payload.values : [];
  if (!values.length) throw appError_("values_required");

  const row = sh.getLastRow() + 1;
  sh.getRange(row, 1, 1, values.length).setValues([values]);
  return { row: row };
}

function updateTotalAset_(payload) {
  const sh = getSheetByToken_(SHEETS.TOTAL_ASET);
  if (!sh) throw appError_("sheet_not_found");

  const row = Number(payload.row || 0);
  const values = Array.isArray(payload.values) ? payload.values : [];
  if (!row || row < 1) throw appError_("row_required");
  if (!values.length) throw appError_("values_required");

  sh.getRange(row, 1, 1, values.length).setValues([values]);
  return { row: row };
}

function deleteTotalAset_(payload) {
  const sh = getSheetByToken_(SHEETS.TOTAL_ASET);
  if (!sh) throw appError_("sheet_not_found");

  const row = Number(payload.row || 0);
  if (!row || row < 2) throw appError_("row_required_data_row");

  const lastCol = Math.max(1, sh.getLastColumn());
  assertDataRow_(row);
  clearRowContentByPolicy_(SHEETS.TOTAL_ASET, sh, row, makeRangeCols_(1, lastCol));
  return { row: row };
}

function assertDataRow_(row) {
  const r = Number(row || 0);
  if (!isFinite(r) || r <= 1) throw appError_("header_row_protected");
}

function clearRowContentByPolicy_(sheetToken, sheet, row, candidateCols) {
  assertDataRow_(row);
  const allowedCols = getAllowedClearColumns_(sheetToken, sheet);
  const allowedMap = {};
  for (let i = 0; i < allowedCols.length; i++) {
    allowedMap[String(allowedCols[i])] = true;
  }

  const requested = Array.isArray(candidateCols) ? candidateCols : [];
  const filtered = [];
  const seen = {};
  for (let j = 0; j < requested.length; j++) {
    const c = Math.floor(Number(requested[j] || 0));
    if (c <= 0) continue;
    if (!allowedMap[String(c)]) continue;
    if (seen[String(c)]) continue;
    seen[String(c)] = true;
    filtered.push(c);
  }

  if (!filtered.length) throw appError_("clear_columns_not_allowed");

  filtered.sort(function(a, b) { return a - b; });
  let start = filtered[0];
  let prev = filtered[0];
  for (let k = 1; k <= filtered.length; k++) {
    const cur = filtered[k];
    if (cur === prev + 1) {
      prev = cur;
      continue;
    }
    sheet.getRange(row, start, 1, prev - start + 1).clearContent();
    start = cur;
    prev = cur;
  }
}

function getAllowedClearColumns_(sheetToken, sheet) {
  if (sheetToken === SHEETS.STOK_MOTOR) {
    // Allowed clear columns: B,C,D,E,F,G,H,I,J,L,M (A and K are protected).
    return [2, 3, 4, 5, 6, 7, 8, 9, 10, 12, 13];
  }
  if (sheetToken === SHEETS.PENGELUARAN_HARIAN) {
    // Allowed clear columns: A,B,C.
    return [1, 2, 3];
  }
  if (sheetToken === SHEETS.TOTAL_ASET) {
    const lastCol = Math.max(1, sheet.getLastColumn());
    return makeRangeCols_(1, lastCol);
  }
  throw appError_("invalid_sheet");
}

function makeRangeCols_(start, end) {
  const s = Math.max(1, Math.floor(Number(start || 1)));
  const e = Math.max(s, Math.floor(Number(end || s)));
  const out = [];
  for (let c = s; c <= e; c++) out.push(c);
  return out;
}

function resolveRow_(sheet, payload, noCol) {
  const rowByPayload = Number(pickAny_(payload, ["row"]));
  if (isFinite(rowByPayload) && rowByPayload >= 2) return rowByPayload;

  const no = normalizeNo_(pickAny_(payload, ["no", "nomor", "id"]));
  if (!no) return 0;
  return findRowByNoWithColumn_(sheet, no, noCol || 1);
}

function detectExpenseColumns_(sheet) {
  const lastCol = Math.max(4, sheet.getLastColumn());
  const headers = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0] || [];

  return {
    noCol: findHeaderColumn_(headers, ["no", "nomor", "id"], 1),
    dateCol: findHeaderColumn_(headers, ["tanggal", "tgl", "date"], 1),
    descCol: findHeaderColumn_(headers, ["keterangan", "catatan", "deskripsi", "detail", "keperluan"], 2),
    amountCol: findHeaderColumn_(headers, ["total pengeluaran", "pengeluaran", "nominal", "jumlah", "biaya", "total", "amount"], 3)
  };
}

function findHeaderColumn_(headers, keywords, fallbackCol) {
  const cols = Array.isArray(headers) ? headers : [];
  const keys = Array.isArray(keywords) ? keywords : [];

  for (let i = 0; i < cols.length; i++) {
    const h = normalizeSearch_(cols[i]);
    if (!h) continue;

    for (let j = 0; j < keys.length; j++) {
      const k = normalizeSearch_(keys[j]);
      if (k && h.indexOf(k) !== -1) return i + 1;
    }
  }

  return Number(fallbackCol || 1);
}

function findMetricValueByLabel_(sheet, normalizedLabel) {
  const lastRow = Math.max(1, sheet.getLastRow());
  const lastCol = Math.max(1, sheet.getLastColumn());
  const raw = sheet.getRange(1, 1, lastRow, lastCol).getValues();
  const disp = sheet.getRange(1, 1, lastRow, lastCol).getDisplayValues();

  for (let r = 0; r < disp.length; r++) {
    for (let c = 0; c < disp[r].length; c++) {
      const text = normalizeSearch_(disp[r][c]);
      if (!text || text.indexOf(normalizedLabel) === -1) continue;

      const candidatePositions = [
        [r, c + 1],
        [r + 1, c],
        [r, c + 2],
        [r + 2, c],
        [r + 1, c + 1]
      ];

      for (let p = 0; p < candidatePositions.length; p++) {
        const rr = candidatePositions[p][0];
        const cc = candidatePositions[p][1];
        if (rr < 0 || cc < 0) continue;
        if (rr >= raw.length) continue;
        if (cc >= raw[rr].length) continue;

        const num = parseNumberValue_(raw[rr][cc]);
        if (num !== null) return num;

        const asText = String(disp[rr][cc] || "").trim();
        if (asText) return asText;
      }
      return null;
    }
  }

  return null;
}

function getSpreadsheet_() {
  if (SPREADSHEET_ID) return SpreadsheetApp.openById(SPREADSHEET_ID);
  return SpreadsheetApp.getActiveSpreadsheet();
}

function getSheetByToken_(token) {
  const ss = getSpreadsheet_();
  if (!ss) return null;
  const key = String(token || "").trim();
  const name = SHEET_NAME_MAP[key];
  if (!name) return null;
  return ss.getSheetByName(name);
}

function parseJsonBody_(e) {
  if (!e || !e.postData || !e.postData.contents) throw appError_("invalid_json");
  try {
    const raw = String(e.postData.contents || "").trim();
    if (!raw) throw appError_("invalid_json");
    const parsed = JSON.parse(raw);
    return ensureObject_(parsed);
  } catch (err) {
    throw appError_("invalid_json");
  }
}

function authorizeApiKey_(incoming) {
  const configured = getConfiguredApiKey_();
  if (!configured) return true;
  return String(incoming || "").trim() === configured;
}

function getConfiguredApiKey_() {
  const hardcoded = String(INTERNAL_API_KEY || "").trim();
  if (hardcoded) return hardcoded;

  try {
    const fromProps = String(PropertiesService.getScriptProperties().getProperty("INTERNAL_API_KEY") || "").trim();
    if (fromProps) return fromProps;
  } catch (err) {
    // ignore
  }

  return "";
}

function normalizeAction_(value) {
  const token = String(value || "").trim().toUpperCase().replace(/[^A-Z_]/g, "");
  if (token === ACTIONS.GET_DATA) return ACTIONS.GET_DATA;
  if (token === ACTIONS.INSERT_DATA) return ACTIONS.INSERT_DATA;
  if (token === ACTIONS.UPDATE_DATA) return ACTIONS.UPDATE_DATA;
  if (token === ACTIONS.DELETE_DATA) return ACTIONS.DELETE_DATA;
  return "";
}

function normalizeSheetToken_(value) {
  const token = String(value || "").trim().toUpperCase().replace(/[^A-Z0-9_ ]/g, "").replace(/\s+/g, " ").trim();
  if (!token) return "";

  if (token === STOK_MOTOR_SHEET_NAME.toUpperCase() || token === "STOK_MOTOR" || token === "STOK MOTOR" || token === "MOTOR") {
    return SHEETS.STOK_MOTOR;
  }
  if (token === PENGELUARAN_HARIAN_SHEET_NAME.toUpperCase() || token === "PENGELUARAN_HARIAN" || token === "PENGELUARAN HARIAN" || token === "EXPENSE") {
    return SHEETS.PENGELUARAN_HARIAN;
  }
  if (token === TOTAL_ASET_SHEET_NAME.toUpperCase() || token === "TOTAL_ASET" || token === "TOTAL ASET" || token === "ASET") {
    return SHEETS.TOTAL_ASET;
  }
  return "";
}

function success_(data) {
  return {
    status: "success",
    data: data === undefined ? null : data
  };
}

function error_(message) {
  return {
    status: "error",
    message: String(message || "error")
  };
}

function appError_(message) {
  const err = new Error(String(message || "error"));
  err.name = "AppError";
  return err;
}

function jsonOutput_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj || {}))
    .setMimeType(ContentService.MimeType.JSON);
}

function findRowByNoWithColumn_(sheet, noInput, noCol) {
  const target = normalizeNo_(noInput);
  const col = Number(noCol || 1);
  if (!target) return 0;

  const startRow = 2;
  const last = sheet.getLastRow();
  if (last < startRow) return 0;

  const vals = sheet.getRange(startRow, col, last - startRow + 1, 1).getDisplayValues();
  for (let i = 0; i < vals.length; i++) {
    if (normalizeNo_(vals[i][0]) === target) return startRow + i;
  }

  return 0;
}

function nextNumericNoByColumn_(sheet, col) {
  const startRow = 2;
  const last = sheet.getLastRow();
  if (last < startRow) return 1;

  const vals = sheet.getRange(startRow, col, last - startRow + 1, 1).getDisplayValues();
  let maxNo = 0;
  for (let i = 0; i < vals.length; i++) {
    const parsed = Number(normalizeNo_(vals[i][0]));
    if (isFinite(parsed) && parsed > maxNo) maxNo = parsed;
  }
  return maxNo + 1;
}

function findFirstEmptyRow_(sheet, startRow, col) {
  const first = Math.max(1, Number(startRow || 1));
  const targetCol = Math.max(1, Number(col || 1));
  const last = Math.max(first, sheet.getLastRow());
  const vals = sheet.getRange(first, targetCol, last - first + 1, 1).getValues();

  for (let i = 0; i < vals.length; i++) {
    if (!vals[i][0]) return first + i;
  }

  return last + 1;
}

function isSoldRow_(rawRow, displayRow) {
  const rawStatus = rawRow && rawRow.length > 12 ? rawRow[12] : "";
  if (rawStatus === true) return true;

  const statusText = normalizeSearch_(displayRow && displayRow.length > 12 ? displayRow[12] : "");
  if (statusText) {
    if (statusText === "true" || statusText === "1" || statusText === "ya" || statusText === "yes") return true;
    if (statusText === "terjual" || statusText === "laku" || statusText === "sold" || statusText === "done") return true;
  }

  const hargaLaku = rawRow && rawRow.length > 8 ? rawRow[8] : "";
  const tglTerjual = rawRow && rawRow.length > 9 ? rawRow[9] : "";
  return isFilledValue_(hargaLaku) || isFilledValue_(tglTerjual);
}

function resolveStatus_(statusInput, hargaLaku, tglTerjual) {
  if (isFilledValue_(hargaLaku) || isFilledValue_(tglTerjual)) return true;
  const s = normalizeSearch_(statusInput);
  if (!s) return false;
  return s === "1" || s === "true" || s === "ya" || s === "yes" || s === "terjual" || s === "laku" || s === "sold" || s === "done";
}

function normalizeStatusFilter_(value) {
  const token = normalizeSearch_(value).replace(/[^a-z0-9_]/g, "_");
  if (!token || token === "all" || token === "semua") return "all";
  if (token === "terjual" || token === "laku" || token === "sold") return "terjual";
  if (token === "belum_terjual" || token === "unsold" || token === "aktif" || token === "stok" || token === "stock") return "belum_terjual";
  return "all";
}

function toBoolValue_(value) {
  if (value === true || value === false) return value;
  const token = normalizeSearch_(value);
  if (!token) return false;
  return token === "1" || token === "true" || token === "yes" || token === "ya" || token === "y" || token === "on";
}

function numberOrDisplay_(rawValue, displayValue) {
  if (typeof rawValue === "number" && isFinite(rawValue)) return rawValue;
  const parsed = parseNumberValue_(displayValue);
  if (parsed !== null) return parsed;
  return String(displayValue || "").trim();
}

function parseDateCell_(rawValue, displayValue) {
  if (rawValue instanceof Date && !isNaN(rawValue.getTime())) return rawValue;
  return parseDateValue_(displayValue);
}

function normalizeDateCell_(rawValue, displayValue) {
  const d = parseDateCell_(rawValue, displayValue);
  return d ? formatDateIso_(d) : String(displayValue || "").trim();
}

function stripTime_(dateObj) {
  if (!(dateObj instanceof Date) || isNaN(dateObj.getTime())) return null;
  return new Date(dateObj.getFullYear(), dateObj.getMonth(), dateObj.getDate());
}

function formatDateIso_(dateObj) {
  const tz = Session.getScriptTimeZone ? Session.getScriptTimeZone() : "Asia/Jakarta";
  return Utilities.formatDate(dateObj, tz, "yyyy-MM-dd");
}

function parseDateValue_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) return value;
  if (value === null || value === undefined) return null;

  const raw = String(value).trim();
  if (!raw) return null;

  let m = raw.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})$/);
  if (m) {
    let yy = Number(m[3]);
    if (yy < 100) yy += 2000;
    const d1 = new Date(yy, Number(m[2]) - 1, Number(m[1]));
    return isNaN(d1.getTime()) ? null : d1;
  }

  m = raw.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
  if (m) {
    const d2 = new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
    return isNaN(d2.getTime()) ? null : d2;
  }

  const d3 = new Date(raw);
  if (!isNaN(d3.getTime())) return d3;
  return null;
}

function parseNumberValue_(value) {
  if (typeof value === "number" && isFinite(value)) return value;
  if (value === null || value === undefined) return null;

  const raw = String(value).trim();
  if (!raw) return null;

  const cleaned = raw.replace(/\./g, "").replace(/,/g, ".").replace(/[^0-9\-.]/g, "");
  if (!cleaned || cleaned === "-" || cleaned === "." || cleaned === "-.") return null;

  const n = Number(cleaned);
  return isFinite(n) ? n : null;
}

function parseNumber_(value) {
  return parseNumberValue_(value);
}

function normalizeNo_(value) {
  return String(value || "").replace(/[^0-9]/g, "").trim();
}

function normalizeSearch_(value) {
  return String(value === undefined || value === null ? "" : value)
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeLimit_(value, fallback, maxLimit) {
  const raw = Number(value);
  const def = Number(fallback || 200);
  const max = Number(maxLimit || 1000);
  if (!isFinite(raw) || raw <= 0) return def;
  return Math.min(Math.max(1, Math.floor(raw)), max);
}

function pickAny_(obj, keys) {
  const src = ensureObject_(obj);
  const list = Array.isArray(keys) ? keys : [];
  for (let i = 0; i < list.length; i++) {
    const k = String(list[i] || "");
    if (k && hasOwn_(src, k)) return src[k];
  }
  return "";
}

function pickString_(obj, keys) {
  const v = pickAny_(obj, keys);
  return String(v === undefined || v === null ? "" : v).trim();
}

function pickNumber_(obj, keys) {
  const v = pickAny_(obj, keys);
  return parseNumber_(v);
}

function pickDate_(obj, keys) {
  const v = pickAny_(obj, keys);
  return parseDateValue_(v);
}

function hasAnyKey_(obj, keys) {
  const src = ensureObject_(obj);
  const list = Array.isArray(keys) ? keys : [];
  for (let i = 0; i < list.length; i++) {
    const k = String(list[i] || "");
    if (k && hasOwn_(src, k)) return true;
  }
  return false;
}

function hasOwn_(obj, key) {
  return Object.prototype.hasOwnProperty.call(obj, key);
}

function ensureObject_(value) {
  return value && typeof value === "object" && !Array.isArray(value) ? value : {};
}

function isFilledValue_(value) {
  if (value === null || value === undefined) return false;
  if (typeof value === "number") return isFinite(value);
  if (value instanceof Date) return !isNaN(value.getTime());
  return String(value).trim() !== "";
}

function isPositiveNumber_(value) {
  return typeof value === "number" && isFinite(value) && value > 0;
}
