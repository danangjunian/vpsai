function doPost(e) {
  try {
    const req = parseJsonBody_(e);

    if (!authorizeApiKey_(req.api_key || req.internal_api_key || "")) {
      return jsonOutput_(error_("unauthorized"));
    }

    const action = normalizeAction_(req.action);
    if (!action) return jsonOutput_(error_("invalid_action"));

    const sheetToken = normalizeSheetToken_(req.sheet);
    if (!sheetToken) return jsonOutput_(error_("invalid_sheet"));

    const payload = ensureObject_(req.payload);
    let data;

    if (action === ACTIONS.GET_DATA) data = handleGetData_(sheetToken, payload);
    else if (action === ACTIONS.INSERT_DATA) data = handleInsertData_(sheetToken, payload);
    else if (action === ACTIONS.UPDATE_DATA) data = handleUpdateData_(sheetToken, payload);
    else if (action === ACTIONS.DELETE_DATA) data = handleDeleteData_(sheetToken, payload);
    else return jsonOutput_(error_("invalid_action"));

    return jsonOutput_(success_(data));
  } catch (err) {
    if (err && err.name === "AppError") return jsonOutput_(error_(err.message));
    return jsonOutput_(error_("executor_error"));
  }
}

function handleGetData_(sheetToken, payload) {
  if (sheetToken === SHEETS.STOK_MOTOR) return getStokMotor_(payload);
  if (sheetToken === SHEETS.PENGELUARAN_HARIAN) return getPengeluaran_(payload);
  if (sheetToken === SHEETS.TOTAL_ASET) return getTotalAset_(payload);
  throw appError_("invalid_sheet");
}

function handleInsertData_(sheetToken, payload) {
  if (sheetToken === SHEETS.STOK_MOTOR) return insertStokMotor_(payload);
  if (sheetToken === SHEETS.PENGELUARAN_HARIAN) return insertPengeluaran_(payload);
  if (sheetToken === SHEETS.TOTAL_ASET) return insertTotalAset_(payload);
  throw appError_("invalid_sheet");
}

function handleUpdateData_(sheetToken, payload) {
