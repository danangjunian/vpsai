}

function handleDeleteData_(sheetToken, payload) {
  if (sheetToken === SHEETS.STOK_MOTOR) return deleteStokMotor_(payload);
  if (sheetToken === SHEETS.PENGELUARAN_HARIAN) return deletePengeluaran_(payload);
  if (sheetToken === SHEETS.TOTAL_ASET) return deleteTotalAset_(payload);
