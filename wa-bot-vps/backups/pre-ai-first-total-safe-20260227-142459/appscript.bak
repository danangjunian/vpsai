function getSessionObject_(key) {
  const k = String(key || "").trim();
  if (!k) return null;
  const now = Date.now();

  // Fast path: CacheService
  try {
    const cache = CacheService.getScriptCache();
    const rawCache = cache.get(k);
    if (rawCache) {
      const parsedCache = parseSessionEnvelope_(rawCache);
      if (parsedCache && parsedCache.expiresAt > now) {
        return parsedCache.data;
      }
      if (parsedCache && parsedCache.expiresAt <= now) {
        clearSessionObject_(k);
        return null;
      }
    }
  } catch (err) {
    // lanjut ke ScriptProperties
  }

  // Fallback kuat: ScriptProperties
  try {
    const props = PropertiesService.getScriptProperties();
    const rawProp = props.getProperty(k);
    if (!rawProp) return null;

    const parsedProp = parseSessionEnvelope_(rawProp);
    if (!parsedProp) {
      props.deleteProperty(k);
      return null;
    }

    if (parsedProp.expiresAt <= now) {
      props.deleteProperty(k);
      try {
        CacheService.getScriptCache().remove(k);
      } catch (cacheErr) {
        // abaikan
      }
      return null;
    }

    try {
      const ttlSec = Math.max(30, Math.floor((parsedProp.expiresAt - now) / 1000));
      CacheService.getScriptCache().put(k, JSON.stringify(parsedProp), ttlSec);
    } catch (cacheErr) {
      // abaikan
    }

    return parsedProp.data;
  } catch (err) {
    return null;
  }
}

function setSessionObject_(key, data, ttlSeconds) {
  const k = String(key || "").trim();
  if (!k) return;

  const ttlSec = Math.max(30, Number(ttlSeconds || 0));
  const expiresAt = Date.now() + ttlSec * 1000;
  const envelope = {
    expiresAt: expiresAt,
    data: data && typeof data === "object" ? data : {}
  };
  const raw = JSON.stringify(envelope);

  // Simpan ke properti dulu supaya durable, cache jadi akselerator.
  try {
    PropertiesService.getScriptProperties().setProperty(k, raw);
  } catch (err) {
    // abaikan; tetap coba cache
  }

  try {
    CacheService.getScriptCache().put(k, raw, ttlSec);
  } catch (err) {
    // abaikan
  }
}

function clearSessionObject_(key) {
  const k = String(key || "").trim();
  if (!k) return;

  try {
    PropertiesService.getScriptProperties().deleteProperty(k);
  } catch (err) {
    // abaikan
  }

  try {
    CacheService.getScriptCache().remove(k);
  } catch (err) {
    // abaikan
  }
}

function parseSessionEnvelope_(raw) {
  try {
    const parsed = JSON.parse(String(raw || ""));
    if (!parsed || typeof parsed !== "object") return null;
    if (!parsed.data || typeof parsed.data !== "object") return null;
    const exp = Number(parsed.expiresAt || 0);
    if (!isFinite(exp) || exp <= 0) return null;
    return {
      expiresAt: exp,
      data: parsed.data
    };
  } catch (err) {
    return null;
  }
}

function sendWa_(target, message) {
  if (!target || !message) return;
  if (!FONNTE_TOKEN) return;
  UrlFetchApp.fetch("https://api.fonnte.com/send", {
    method: "post",
    headers: { Authorization: FONNTE_TOKEN },
    payload: {
      target: target,
      message: message
    },
    muteHttpExceptions: true
  });
}

function log_(message) {
  if (DEBUG_MODE) Logger.log(message);
}

function jsonOutput_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj || {}))
    .setMimeType(ContentService.MimeType.JSON);
}

function jsonOutputWithDedup_(obj, messageId) {
  const payload = obj || {};
  setDedupResponseByMessageId_(messageId, payload);
  return jsonOutput_(payload);
}

function getDedupResponseByMessageId_(messageId) {
  const key = dedupCacheKey_(messageId);
  if (!key) return null;
  try {
    const cache = CacheService.getScriptCache();
    const raw = cache.get(key);
    if (!raw) return null;
    return JSON.parse(raw);
  } catch (err) {
    return null;
  }
}

function setDedupResponseByMessageId_(messageId, payload) {
  const key = dedupCacheKey_(messageId);
  if (!key) return;
  try {
    const cache = CacheService.getScriptCache();
    cache.put(key, JSON.stringify(payload || {}), 6 * 60 * 60); // 6 jam
  } catch (err) {
    // abaikan error cache agar proses utama tidak terganggu
  }
}

function dedupCacheKey_(messageId) {
  const id = String(messageId || "").trim();
  if (!id) return "";
  return "wa:msg:" + id.slice(0, 200);
}

function evaluateWaSourceFilter_(ctx) {
  if (!ENABLE_WA_SOURCE_FILTER) return { ok: true };

  const adminSet = buildWaNumberSet_(ADMIN_WA_NUMBERS);
  const sender = normalizeWaIdentity_(ctx && ctx.sender);
  const chatJid = normalizeWaIdentity_(ctx && ctx.chatJid);
  const botId = normalizeWaIdentity_((ctx && ctx.botJid) || BOT_WA_NUMBER);
  const fromMe = Boolean(ctx && ctx.fromMe);

  // Kalau bot ID kosong, jangan blokir agar tidak mematikan service.
  if (!botId) return { ok: true };

  const isSenderBot = sender && sender === botId;
  const isSelfChat = chatJid && chatJid === botId;
  const isAdminSender = Boolean(sender && adminSet.has(sender));

  // Izinkan self-chat bot (sesuai requirement).
  if (isSenderBot && isSelfChat) return { ok: true };

  // Tolak pesan keluar dari bot ke nomor lain.
  if (isSenderBot && chatJid && !isSelfChat) {
    return {
      ok: false,
      error: "WA_FILTER_BLOCK_BOT_OUTBOUND",
      reply: "IGNORED: bot outbound message"
    };
  }

  // Izinkan nomor admin.
  if (isAdminSender) return { ok: true };

  // Fallback: jika ditandai fromMe dan bukan self-chat, tolak juga.
  if (fromMe && chatJid && !isSelfChat) {
    return {
      ok: false,
      error: "WA_FILTER_BLOCK_FROM_ME_OUTBOUND",
      reply: "IGNORED: fromMe outbound message"
    };
  }

  // Selain admin/self, tolak.
  return {
    ok: false,
    error: "WA_FILTER_BLOCK_NON_ADMIN",
    reply: "IGNORED: non-admin sender"
  };
}

function normalizeWaIdentity_(value) {
  const raw = String(value || "").trim().toLowerCase();
  if (!raw) return "";

  // Group JID tidak dipakai untuk compare bot personal.
  if (raw.indexOf("@g.us") !== -1) {
    return "group:" + raw.split("@")[0];
  }

  const noPlus = raw.replace(/^\+/, "");
  const beforeAt = noPlus.split("@")[0];
  const beforeDevice = beforeAt.split(":")[0];
  const digits = beforeDevice.replace(/[^\d]/g, "");
  return digits || beforeDevice;
}

function parseBoolLike_(value) {
  if (value === true || value === false) return value;
  const v = String(value === undefined || value === null ? "" : value).trim().toLowerCase();
  if (!v) return false;
  return ["1", "true", "yes", "y", "on"].indexOf(v) !== -1;
}

function buildWaNumberSet_(values) {
  const list = Array.isArray(values) ? values : [];
  const out = {};
  for (let i = 0; i < list.length; i++) {
    const n = normalizeWaIdentity_(list[i]);
    if (n) out[n] = true;
  }
  return {
    has: function (value) {
      const n = normalizeWaIdentity_(value);
      return Boolean(n && out[n]);
    }
  };
}
