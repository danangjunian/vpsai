function doGet(e) {
  const payload = extractDataExecutorPayload_(e);
  return jsonOutput_(handleDataExecutor_(payload));
}

function doPost(e) {
  const payload = extractDataExecutorPayload_(e);
  return jsonOutput_(handleDataExecutor_(payload));
}

function extractDataExecutorPayload_(e) {
  try {
    if (e && e.postData && e.postData.contents) {
      const raw = String(e.postData.contents || "").trim();
      if (raw) return JSON.parse(raw);
    }
  } catch (err) {
    return { intent: "", error: "INVALID_JSON" };
  }

  if (e && e.parameter) {
    if (e.parameter.payload) {
      try {
        return JSON.parse(String(e.parameter.payload || ""));
      } catch (err) {
        return { intent: "", error: "INVALID_JSON" };
      }
    }
    return e.parameter;
  }

  return {};
}

function handleDataExecutor_(payload) {
  try {
    const req = normalizeDataRequest_(payload);
    if (!req.intent) return makeDataResponse_("ERROR", null, "INTENT_REQUIRED");

    if (req.intent === "GET_DATA") return handleGetData_(req);
    if (req.intent === "ADD_DATA") return handleAddData_(req);
    if (req.intent === "EDIT_DATA") return handleEditData_(req);
    if (req.intent === "DELETE_DATA") return handleDeleteData_(req);
    if (req.intent === "MARK_SOLD") return handleMarkSold_(req);

    return makeDataResponse_("ERROR", null, "INTENT_UNKNOWN");
  } catch (err) {
    return makeDataResponse_("ERROR", null, String(err && err.message ? err.message : err));
  }
}

function normalizeDataRequest_(payload) {
  const src = ensureObject_(payload);
  const intent = normalizeIntentToken_(src.intent || src.action || "");
  const entity = normalizeEntityToken_(src.entity || src.target || "");
  const filters = ensureObject_(src.filters || src.filter);
  const updates = ensureObject_(src.updates || src.data || src.payload);

  return {
    intent: intent,
    entity: entity || (intent ? "motor" : ""),
    name: String(src.name || src.nama || src.nama_motor || "").trim(),
    no: normalizeNo_(src.no || src.nomor || ""),
    status: normalizeStatusToken_(src.status || filters.status || ""),
    filters: filters,
    updates: updates,
    limit: src.limit !== undefined ? src.limit : filters.limit
  };
}

function handleGetData_(req) {
  const entity = req.entity || "motor";
  if (entity === "ai_memory") return handleGetAiMemory_(req);
  if (entity === "expense") return handleGetExpense_(req);
  if (entity === "motor") return handleGetMotor_(req);
  return makeDataResponse_("ERROR", null, "ENTITY_NOT_SUPPORTED");
}

function handleAddData_(req) {
  const entity = req.entity || "motor";
  if (entity === "ai_memory") return handleAddAiMemory_(req);
  if (entity === "expense") return handleAddExpense_(req);
  if (entity === "motor") return handleAddMotor_(req);
  return makeDataResponse_("ERROR", null, "ENTITY_NOT_SUPPORTED");
}

function handleEditData_(req) {
  const entity = req.entity || "motor";
  if (entity === "expense") return handleEditExpense_(req);
  if (entity === "motor") return handleEditMotor_(req);
  return makeDataResponse_("ERROR", null, "ENTITY_NOT_SUPPORTED");
}

function handleDeleteData_(req) {
  const entity = req.entity || "motor";
  if (entity === "expense") return handleDeleteExpense_(req);
  if (entity === "motor") return handleDeleteMotor_(req);
  return makeDataResponse_("ERROR", null, "ENTITY_NOT_SUPPORTED");
}

function handleMarkSold_(req) {
  const entity = req.entity || "motor";
  if (entity !== "motor") return makeDataResponse_("ERROR", null, "ENTITY_NOT_SUPPORTED");
  return handleMarkSoldMotor_(req);
}

function handleGetMotor_(req) {
  const selector = {
    no: req.no,
    name: req.name,
    status: req.status
  };
  const q = queryMotorRows_(selector);
  if (!q.ok) return makeDataResponse_("ERROR", null, q.error);
  if (!q.rows.length) return makeDataResponse_("NOT_FOUND", null, "");

  const limit = resolveListLimit_(req, 50);
  if (q.rows.length === 1) {
    return makeDataResponse_("SINGLE", formatMotorDetail_(q.rows[0]), "");
  }

  const list = q.rows.slice(0, limit).map(formatMotorListItem_);
  return makeDataResponse_("MULTIPLE", list, "");
}

function handleAddMotor_(req) {
  const updates = normalizeMotorUpdates_(req.updates);
  if (!updates.nama_motor && req.name) updates.nama_motor = req.name;

  const required = ["nama_motor", "tahun", "plat", "surat_surat", "tahun_plat", "pajak", "harga_jual", "harga_beli"];
  const missing = [];
  for (let i = 0; i < required.length; i++) {
    if (!isFilledValue_(updates[required[i]])) missing.push(required[i]);
  }
  if (missing.length) {
    return makeDataResponse_("ERROR", null, "MISSING_FIELDS: " + missing.join(", "));
  }

  const cols = buildMotorColsFromUpdates_(updates);
  const saved = saveToSheet_(cols);
  if (!saved.ok) return makeDataResponse_("ERROR", null, saved.error);
  return makeDataResponse_("SINGLE", { row: saved.row }, "");
}

function handleEditMotor_(req) {
  const updates = normalizeMotorUpdates_(req.updates);
  if (!hasAnyUpdate_(updates)) return makeDataResponse_("ERROR", null, "UPDATES_REQUIRED");

  let targetNo = normalizeNo_(req.no);
  if (!targetNo) {
    const q = queryMotorRows_({
      no: "",
      name: req.name,
      status: req.status
    });
    if (!q.ok) return makeDataResponse_("ERROR", null, q.error);
    if (!q.rows.length) return makeDataResponse_("NOT_FOUND", null, "");
    if (q.rows.length > 1) {
      const list = q.rows.slice(0, resolveListLimit_(req, 50)).map(formatMotorListItem_);
      return makeDataResponse_("MULTIPLE", list, "");
    }
    targetNo = normalizeNo_(q.rows[0].no);
  }

  const cols = buildMotorColsFromUpdates_(updates);
  const updated = updateMotorDataByNo_(targetNo, cols);
  if (!updated.ok) return makeDataResponse_("ERROR", null, updated.error);
  return makeDataResponse_("SINGLE", { row: updated.row, no: targetNo }, "");
}

function handleDeleteMotor_(req) {
  let targetNo = normalizeNo_(req.no);
  if (!targetNo) {
    const q = queryMotorRows_({
      no: "",
      name: req.name,
      status: req.status
    });
    if (!q.ok) return makeDataResponse_("ERROR", null, q.error);
    if (!q.rows.length) return makeDataResponse_("NOT_FOUND", null, "");
    if (q.rows.length > 1) {
      const list = q.rows.slice(0, resolveListLimit_(req, 50)).map(formatMotorListItem_);
      return makeDataResponse_("MULTIPLE", list, "");
    }
    targetNo = normalizeNo_(q.rows[0].no);
  }

  const removed = deleteMotorByNo_(targetNo);
  if (!removed.ok) return makeDataResponse_("ERROR", null, removed.error);
  return makeDataResponse_("SINGLE", { row: removed.row, no: targetNo }, "");
}

function handleMarkSoldMotor_(req) {
  const updates = normalizeMotorUpdates_(req.updates);
  if (!isFilledValue_(updates.harga_laku)) return makeDataResponse_("ERROR", null, "HARGA_LAKU_REQUIRED");

  let targetNo = normalizeNo_(req.no);
  if (!targetNo) {
    const q = queryMotorRows_({
      no: "",
      name: req.name,
      status: "belum_terjual"
    });
    if (!q.ok) return makeDataResponse_("ERROR", null, q.error);
    if (!q.rows.length) return makeDataResponse_("NOT_FOUND", null, "");
    if (q.rows.length > 1) {
      const list = q.rows.slice(0, resolveListLimit_(req, 50)).map(formatMotorListItem_);
      return makeDataResponse_("MULTIPLE", list, "");
    }
    targetNo = normalizeNo_(q.rows[0].no);
  }

  const cols = [
    targetNo,
    "", // harga_jual
    updates.harga_laku,
    updates.tgl_terjual || "",
    "terjual"
  ];
  const updated = updateSoldData_(cols);
  if (!updated.ok) return makeDataResponse_("ERROR", null, updated.error);
  return makeDataResponse_("SINGLE", { row: updated.row, no: targetNo }, "");
}

function handleGetExpense_(req) {
  const all = readAllExpenseRows_();
  if (!all.ok) return makeDataResponse_("ERROR", null, all.error);

  let rows = all.rows.slice();
  const targetNo = normalizeNo_(req.no);
  if (targetNo) {
    rows = rows.filter(function (r) { return normalizeNo_(r.no) === targetNo; });
  }

  const dateKey = extractExpenseDateFilter_(req);
  if (dateKey) {
    rows = rows.filter(function (r) { return normalizeDateKey_(r.tanggal) === dateKey; });
  }

  if (!rows.length) return makeDataResponse_("NOT_FOUND", null, "");

  const limit = resolveListLimit_(req, 50);
  if (rows.length === 1) return makeDataResponse_("SINGLE", formatExpenseDetail_(rows[0]), "");
  return makeDataResponse_("MULTIPLE", rows.slice(0, limit).map(formatExpenseListItem_), "");
}

function handleAddExpense_(req) {
  const updates = normalizeExpenseUpdates_(req.updates);
  if (!updates.keterangan || !isFilledValue_(updates.total_pengeluaran)) {
    return makeDataResponse_("ERROR", null, "EXPENSE_FIELDS_REQUIRED");
  }

  const cols = [
    updates.keterangan,
    updates.total_pengeluaran,
    updates.tanggal || ""
  ];
  const saved = saveDailyExpenseData_(cols);
  if (!saved.ok) return makeDataResponse_("ERROR", null, saved.error);
  return makeDataResponse_("SINGLE", { row: saved.row }, "");
}

function handleEditExpense_(req) {
  const targetNo = normalizeNo_(req.no);
  if (!targetNo) {
    const all = readAllExpenseRows_();
    if (!all.ok) return makeDataResponse_("ERROR", null, all.error);
    let rows = all.rows.slice();
    const dateKey = extractExpenseDateFilter_(req);
    if (dateKey) {
      rows = rows.filter(function (r) { return normalizeDateKey_(r.tanggal) === dateKey; });
    }
    if (!rows.length) return makeDataResponse_("NOT_FOUND", null, "");
    const limit = resolveListLimit_(req, 50);
    if (rows.length === 1) return makeDataResponse_("SINGLE", formatExpenseDetail_(rows[0]), "");
    return makeDataResponse_("MULTIPLE", rows.slice(0, limit).map(formatExpenseListItem_), "");
  }

  const updates = normalizeExpenseUpdates_(req.updates);
  if (!hasAnyExpenseUpdate_(updates)) return makeDataResponse_("ERROR", null, "UPDATES_REQUIRED");

  const updated = updateExpenseDataByNo_(targetNo, updates);
  if (!updated.ok) return makeDataResponse_("ERROR", null, updated.error);
  return makeDataResponse_("SINGLE", { row: updated.row, no: targetNo }, "");
}

function handleDeleteExpense_(req) {
  const targetNo = normalizeNo_(req.no);
  if (!targetNo) {
    const all = readAllExpenseRows_();
    if (!all.ok) return makeDataResponse_("ERROR", null, all.error);
    const limit = resolveListLimit_(req, 50);
    if (!all.rows.length) return makeDataResponse_("NOT_FOUND", null, "");
    if (all.rows.length === 1) return makeDataResponse_("SINGLE", formatExpenseDetail_(all.rows[0]), "");
    return makeDataResponse_("MULTIPLE", all.rows.slice(0, limit).map(formatExpenseListItem_), "");
  }

  const removed = deleteExpenseDataByNo_(targetNo);
  if (!removed.ok) return makeDataResponse_("ERROR", null, removed.error);
  return makeDataResponse_("SINGLE", { row: removed.row, no: targetNo }, "");
}

function handleGetAiMemory_(req) {
  const all = readAllAiMemoryRows_();
  if (!all.ok) return makeDataResponse_("ERROR", null, all.error);

  let rows = all.rows.slice();
  const filters = ensureObject_(req.filters);
  const sessionKey = String(
    req.session_key ||
    req.sessionKey ||
    filters.session_key ||
    filters.sessionKey ||
    ""
  ).trim();

  if (sessionKey) {
    rows = rows.filter(function (r) {
      return String(r.session_key || "").trim() === sessionKey;
    });
  }

  if (!rows.length) return makeDataResponse_("NOT_FOUND", null, "");

  rows.sort(function (a, b) {
    return Number(b.row || 0) - Number(a.row || 0);
  });

  const limit = resolveListLimit_(req, 10);
  if (rows.length === 1) return makeDataResponse_("SINGLE", rows[0], "");
  return makeDataResponse_("MULTIPLE", rows.slice(0, limit), "");
}

function handleAddAiMemory_(req) {
  const updates = ensureObject_(req.updates);
  const saved = saveAiMemoryData_(updates);
  if (!saved.ok) return makeDataResponse_("ERROR", null, saved.error);
  return makeDataResponse_("SINGLE", { row: saved.row }, "");
}

function saveAiMemoryData_(updates) {
  try {
    const src = ensureObject_(updates);
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca." };

    const sh = ss.getSheetByName(AI_MEMORY_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + AI_MEMORY_SHEET_NAME + '" tidak ditemukan' };

    const map = detectAiMemoryColumns_(sh);
    const row = findFirstEmptyRow_(sh, 2, map.userCol);

    sh.getRange(row, map.dateCol).setValue(resolveAiMemoryDate_(src.created_at || src.timestamp || ""));
    sh.getRange(row, map.sessionCol).setValue(String(src.session_key || src.sessionKey || "").trim());
    sh.getRange(row, map.userCol).setValue(String(src.user_text || src.userText || "").trim());
    sh.getRange(row, map.aiCol).setValue(String(src.ai_json || src.aiDecision || "").trim());
    sh.getRange(row, map.executorCol).setValue(String(src.executor_json || src.executorResult || "").trim());
    sh.getRange(row, map.replyCol).setValue(String(src.reply_text || src.replyText || "").trim());
    sh.getRange(row, map.noteCol).setValue(String(src.note || "").trim());

    if (map.noCol > 0 && !sh.getRange(row, map.noCol).getValue()) {
      sh.getRange(row, map.noCol).setValue(row - 1);
    }

    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function readAllAiMemoryRows_() {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca.", rows: [] };

    const sh = ss.getSheetByName(AI_MEMORY_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + AI_MEMORY_SHEET_NAME + '" tidak ditemukan', rows: [] };

    const map = detectAiMemoryColumns_(sh);
    const start = 2;
    const last = sh.getLastRow();
    if (last < start) return { ok: true, rows: [] };

    const width = Math.max(
      sh.getLastColumn(),
      map.noCol,
      map.dateCol,
      map.sessionCol,
      map.userCol,
      map.aiCol,
      map.executorCol,
      map.replyCol,
      map.noteCol
    );
    const rawVals = sh.getRange(start, 1, last - start + 1, width).getValues();
    const displayVals = sh.getRange(start, 1, last - start + 1, width).getDisplayValues();
    const rows = [];

    for (let i = 0; i < rawVals.length; i++) {
      const raw = rawVals[i];
      const disp = displayVals[i];
      const sessionKey = String(disp[map.sessionCol - 1] || "").trim();
      const userText = String(disp[map.userCol - 1] || "").trim();
      const aiJson = String(disp[map.aiCol - 1] || "").trim();
      const executorJson = String(disp[map.executorCol - 1] || "").trim();
      const replyText = String(disp[map.replyCol - 1] || "").trim();
      const note = String(disp[map.noteCol - 1] || "").trim();
      if (!sessionKey && !userText && !aiJson && !executorJson && !replyText && !note) continue;

      const rawDate = raw[map.dateCol - 1];
      const dispDate = disp[map.dateCol - 1];
      const parsedDate = parseDateCell_(rawDate, dispDate);

      rows.push({
        row: start + i,
        no: normalizeNo_(disp[map.noCol - 1]),
        created_at: parsedDate ? formatDateForReport_(parsedDate) : String(dispDate || "").trim(),
        session_key: sessionKey,
        user_text: userText,
        ai_json: aiJson,
        executor_json: executorJson,
        reply_text: replyText,
        note: note
      });
    }

    return { ok: true, rows: rows };
  } catch (err) {
    return { ok: false, error: "Gagal baca AI memory: " + err.message, rows: [] };
  }
}

function detectAiMemoryColumns_(sheet) {
  const lastCol = Math.max(sheet.getLastColumn(), 8);
  const headers = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0] || [];
  const noIndex = findHeaderIndex_(headers, ["no", "nomor", "id"]);
  const dateIndex = findHeaderIndex_(headers, ["created_at", "timestamp", "waktu", "tanggal", "date"]);
  const sessionIndex = findHeaderIndex_(headers, ["session_key", "session", "chat"]);
  const userIndex = findHeaderIndex_(headers, ["user_text", "user", "pesan", "message", "prompt"]);
  const aiIndex = findHeaderIndex_(headers, ["ai_json", "ai", "decision", "intent_json"]);
  const executorIndex = findHeaderIndex_(headers, ["executor_json", "executor", "result_json", "hasil_json"]);
  const replyIndex = findHeaderIndex_(headers, ["reply_text", "reply", "jawaban", "response"]);
  const noteIndex = findHeaderIndex_(headers, ["note", "catatan", "tag", "type"]);

  return {
    noCol: noIndex >= 0 ? noIndex + 1 : 1,
    dateCol: dateIndex >= 0 ? dateIndex + 1 : 2,
    sessionCol: sessionIndex >= 0 ? sessionIndex + 1 : 3,
    userCol: userIndex >= 0 ? userIndex + 1 : 4,
    aiCol: aiIndex >= 0 ? aiIndex + 1 : 5,
    executorCol: executorIndex >= 0 ? executorIndex + 1 : 6,
    replyCol: replyIndex >= 0 ? replyIndex + 1 : 7,
    noteCol: noteIndex >= 0 ? noteIndex + 1 : 8
  };
}

function resolveAiMemoryDate_(value) {
  const raw = String(value || "").trim();
  if (!raw) return new Date();

  const fromParseDate = parseDate_(raw);
  if (fromParseDate instanceof Date && !isNaN(fromParseDate.getTime())) {
    return fromParseDate;
  }

  const fromCell = parseDateCell_(raw, raw);
  if (fromCell instanceof Date && !isNaN(fromCell.getTime())) {
    return fromCell;
  }

  return new Date();
}

function queryMotorRows_(selector) {
  const src = ensureObject_(selector);
  const all = readAllMotorRows_();
  if (!all.ok) return all;

  const qNo = normalizeNo_(src.no || "");
  const qNameTokens = splitSearchTokens_(src.name || "");
  const qStatus = normalizeStatusToken_(src.status || "");

  const filtered = all.rows.filter(function (row) {
    if (qNo && normalizeNo_(row.no) !== qNo) return false;
    if (qNameTokens.length) {
      const name = normalizeText_(row.nama || "");
      for (let i = 0; i < qNameTokens.length; i++) {
        if (name.indexOf(qNameTokens[i]) === -1) return false;
      }
    }
    if (qStatus === "terjual" && !row.is_sold) return false;
    if (qStatus === "belum_terjual" && row.is_sold) return false;
    return true;
  });

  return { ok: true, rows: filtered };
}

function readAllMotorRows_() {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca.", rows: [] };
    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + SHEET_NAME + '" tidak ditemukan', rows: [] };

    const startRow = 2;
    const last = sh.getLastRow();
    if (last < startRow) return { ok: true, rows: [] };

    const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
    const rawVals = range.getValues();
    const displayVals = range.getDisplayValues();
    const rows = [];

    for (let i = 0; i < rawVals.length; i++) {
      const raw = rawVals[i];
      const disp = displayVals[i];
      const no = normalizeNo_(disp[0]);
      const nama = String(disp[1] || "").trim();
      if (!no) continue;

      const isSold = isSoldStatusValue_(raw, disp);
      rows.push({
        row: startRow + i,
        no: no,
        nama: nama,
        tahun: String(disp[2] || "").trim(),
        plat: String(disp[3] || "").trim(),
        surat_surat: String(disp[4] || "").trim(),
        tahun_plat: String(disp[5] || "").trim(),
        pajak: String(disp[6] || "").trim(),
        harga_jual: normalizeCellNumber_(raw[7], disp[7]),
        harga_laku: normalizeCellNumber_(raw[8], disp[8]),
        tgl_terjual: normalizeCellDate_(raw[9], disp[9]),
        harga_beli: normalizeCellNumber_(raw[11], disp[11]),
        status: isSold ? "terjual" : "belum_terjual",
        is_sold: isSold
      });
    }

    return { ok: true, rows: rows };
  } catch (err) {
    return { ok: false, error: "Gagal baca data motor: " + err.message, rows: [] };
  }
}

function deleteMotorByNo_(noInput) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca." };
    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + SHEET_NAME + '" tidak ditemukan' };
    const row = findRowByNo_(sh, noInput);
    if (!row) return { ok: false, error: "NO tidak ditemukan: " + normalizeNo_(noInput) };
    sh.deleteRow(row);
    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function readAllExpenseRows_() {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca.", rows: [] };
    const sh = ss.getSheetByName(EXPENSE_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + EXPENSE_SHEET_NAME + '" tidak ditemukan', rows: [] };

    const map = detectExpenseColumnsFull_(sh);
    const start = 2;
    const last = sh.getLastRow();
    if (last < start) return { ok: true, rows: [] };

    const width = Math.max(sh.getLastColumn(), map.noCol, map.dateCol, map.descCol, map.amountCol);
    const vals = sh.getRange(start, 1, last - start + 1, width).getValues();
    const disp = sh.getRange(start, 1, last - start + 1, width).getDisplayValues();
    const rows = [];

    for (let i = 0; i < vals.length; i++) {
      const no = normalizeNo_(disp[i][map.noCol - 1]);
      const tanggal = parseDateCell_(vals[i][map.dateCol - 1], disp[i][map.dateCol - 1]);
      const keterangan = String(disp[i][map.descCol - 1] || "").trim();
      const total = parseAmountCell_(vals[i][map.amountCol - 1], disp[i][map.amountCol - 1]);
      if (!no) continue;
      rows.push({
        row: start + i,
        no: no,
        tanggal: tanggal ? formatDateForReport_(tanggal) : String(disp[i][map.dateCol - 1] || ""),
        keterangan: keterangan,
        total_pengeluaran: total || 0
      });
    }

    return { ok: true, rows: rows };
  } catch (err) {
    return { ok: false, error: "Gagal baca pengeluaran: " + err.message, rows: [] };
  }
}

function detectExpenseColumnsFull_(sheet) {
  const lastCol = Math.max(sheet.getLastColumn(), 4);
  const headers = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0] || [];
  const noIndex = findHeaderIndex_(headers, ["no", "nomor", "id"]);
  const dateIndex = findHeaderIndex_(headers, ["tanggal", "tgl", "date"]);
  const descIndex = findHeaderIndex_(headers, ["keterangan", "catatan", "deskripsi", "detail"]);
  const amountIndex = findHeaderIndex_(headers, ["total pengeluaran", "pengeluaran", "nominal", "jumlah", "biaya", "total", "amount"]);
  return {
    noCol: noIndex >= 0 ? noIndex + 1 : 1,
    dateCol: dateIndex >= 0 ? dateIndex + 1 : 1,
    descCol: descIndex >= 0 ? descIndex + 1 : 2,
    amountCol: amountIndex >= 0 ? amountIndex + 1 : 3
  };
}

function updateExpenseDataByNo_(noInput, updates) {
  try {
    const no = normalizeNo_(noInput);
    if (!no) return { ok: false, error: "NO wajib diisi." };

    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca." };
    const sh = ss.getSheetByName(EXPENSE_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + EXPENSE_SHEET_NAME + '" tidak ditemukan' };

    const map = detectExpenseColumnsFull_(sh);
    const row = findExpenseRowByNo_(sh, no, map.noCol);
    if (!row) return { ok: false, error: "NO tidak ditemukan: " + no };

    if (String(updates.keterangan || "").trim()) {
      sh.getRange(row, map.descCol).setValue(String(updates.keterangan || "").trim());
    }
    if (isFilledValue_(updates.total_pengeluaran)) {
      const total = parseNumber_(updates.total_pengeluaran);
      if (!(typeof total === "number" && isFinite(total) && total > 0)) {
        return { ok: false, error: "Nominal pengeluaran tidak valid." };
      }
      sh.getRange(row, map.amountCol).setValue(total);
    }
    if (String(updates.tanggal || "").trim()) {
      sh.getRange(row, map.dateCol).setValue(resolveExpenseDate_(updates.tanggal));
    }

    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function deleteExpenseDataByNo_(noInput) {
  try {
    const no = normalizeNo_(noInput);
    if (!no) return { ok: false, error: "NO wajib diisi." };
    const ss = getSpreadsheet_();
    if (!ss) return { ok: false, error: "Spreadsheet tidak terbaca." };
    const sh = ss.getSheetByName(EXPENSE_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + EXPENSE_SHEET_NAME + '" tidak ditemukan' };
    const map = detectExpenseColumnsFull_(sh);
    const row = findExpenseRowByNo_(sh, no, map.noCol);
    if (!row) return { ok: false, error: "NO tidak ditemukan: " + no };
    sh.getRange(row, map.dateCol).clearContent();
    sh.getRange(row, map.descCol).clearContent();
    sh.getRange(row, map.amountCol).clearContent();
    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function findExpenseRowByNo_(sheet, noInput, noCol) {
  const target = normalizeNo_(noInput);
  if (!target) return 0;
  const col = Number(noCol || 1);
  const startRow = 2;
  const last = sheet.getLastRow();
  if (last < startRow) return 0;
  const vals = sheet.getRange(startRow, col, last - startRow + 1, 1).getDisplayValues();
  for (let i = 0; i < vals.length; i++) {
    if (normalizeNo_(vals[i][0]) === target) return startRow + i;
  }
  return 0;
}

function extractExpenseDateFilter_(req) {
  const filters = ensureObject_(req.filters);
  const candidates = [
    req.tanggal,
    req.date,
    filters.tanggal,
    filters.date,
    filters.start_date
  ];
  for (let i = 0; i < candidates.length; i++) {
    const key = normalizeDateKey_(candidates[i]);
    if (key) return key;
  }
  return "";
}

function normalizeMotorUpdates_(updates) {
  const src = ensureObject_(updates);
  return {
    nama_motor: pickFirst_(src, ["nama_motor", "nama", "name", "motor_name"]),
    tahun: pickFirst_(src, ["tahun"]),
    plat: pickFirst_(src, ["plat"]),
    surat_surat: pickFirst_(src, ["surat_surat", "surat"]),
    tahun_plat: pickFirst_(src, ["tahun_plat", "tahunplat", "thn_plat"]),
    pajak: pickFirst_(src, ["pajak"]),
    harga_jual: pickFirst_(src, ["harga_jual", "hargaJual", "jual"]),
    harga_beli: pickFirst_(src, ["harga_beli", "hargaBeli", "beli"]),
    harga_laku: pickFirst_(src, ["harga_laku", "hargaLaku", "laku"]),
    tgl_terjual: pickFirst_(src, ["tgl_terjual", "tanggal_terjual", "tglTerjual"]),
    status: pickFirst_(src, ["status"])
  };
}

function normalizeExpenseUpdates_(updates) {
  const src = ensureObject_(updates);
  return {
    keterangan: pickFirst_(src, ["keterangan", "catatan", "deskripsi", "detail"]),
    total_pengeluaran: pickFirst_(src, ["total_pengeluaran", "nominal", "jumlah", "biaya", "total"]),
    tanggal: pickFirst_(src, ["tanggal", "tgl", "date"])
  };
}

function buildMotorColsFromUpdates_(updates) {
  return [
    updates.nama_motor || "",
    updates.tahun || "",
    updates.plat || "",
    updates.surat_surat || "",
    updates.tahun_plat || "",
    updates.pajak || "",
    updates.harga_jual || "",
    updates.harga_laku || "",
    updates.harga_beli || "",
    updates.tgl_terjual || "",
    updates.status || ""
  ];
}

function hasAnyUpdate_(updates) {
  const src = ensureObject_(updates);
  const keys = ["nama_motor", "tahun", "plat", "surat_surat", "tahun_plat", "pajak", "harga_jual", "harga_beli", "harga_laku", "tgl_terjual", "status"];
  for (let i = 0; i < keys.length; i++) {
    if (isFilledValue_(src[keys[i]])) return true;
  }
  return false;
}

function hasAnyExpenseUpdate_(updates) {
  const src = ensureObject_(updates);
  return (
    isFilledValue_(src.keterangan) ||
    isFilledValue_(src.total_pengeluaran) ||
    isFilledValue_(src.tanggal)
  );
}

function formatMotorListItem_(row) {
  return {
    no: row.no || "",
    nama: row.nama || "",
    plat: row.plat || ""
  };
}

function formatMotorDetail_(row) {
  return {
    no: row.no || "",
    nama: row.nama || "",
    tahun: row.tahun || "",
    plat: row.plat || "",
    surat_surat: row.surat_surat || "",
    tahun_plat: row.tahun_plat || "",
    pajak: row.pajak || "",
    harga_jual: row.harga_jual,
    harga_beli: row.harga_beli,
    harga_laku: row.harga_laku,
    tgl_terjual: row.tgl_terjual || "",
    status: row.status || ""
  };
}

function formatExpenseListItem_(row) {
  return {
    no: row.no || "",
    tanggal: row.tanggal || "",
    keterangan: row.keterangan || "",
    total_pengeluaran: row.total_pengeluaran || 0
  };
}

function formatExpenseDetail_(row) {
  return {
    no: row.no || "",
    tanggal: row.tanggal || "",
    keterangan: row.keterangan || "",
    total_pengeluaran: row.total_pengeluaran || 0
  };
}

function makeDataResponse_(status, data, error) {
  const s = String(status || "").trim().toUpperCase();
  return {
    status: s || "ERROR",
    data: data !== undefined ? data : null,
    error: error ? String(error) : ""
  };
}

function resolveListLimit_(req, fallback) {
  const raw = Number(req && req.limit !== undefined ? req.limit : fallback);
  if (!isFinite(raw) || raw <= 0) return fallback;
  return Math.min(Math.max(1, Math.floor(raw)), 200);
}

function normalizeCellNumber_(raw, disp) {
  if (typeof raw === "number" && isFinite(raw)) return raw;
  const parsed = parseNumber_(disp);
  if (typeof parsed === "number" && isFinite(parsed)) return parsed;
  return String(disp || "").trim();
}

function normalizeCellDate_(raw, disp) {
  const d = parseDateCell_(raw, disp);
  return d ? formatDateForReport_(d) : String(disp || "").trim();
}

function normalizeIntentToken_(value) {
  const token = String(value || "").trim().toUpperCase().replace(/[^\w]+/g, "_");
  const alias = {
    GET: "GET_DATA",
    GET_DATA: "GET_DATA",
    ADD: "ADD_DATA",
    ADD_DATA: "ADD_DATA",
    INPUT_DATA: "ADD_DATA",
    EDIT: "EDIT_DATA",
    EDIT_DATA: "EDIT_DATA",
    UPDATE_DATA: "EDIT_DATA",
    DELETE: "DELETE_DATA",
    DELETE_DATA: "DELETE_DATA",
    HAPUS_DATA: "DELETE_DATA",
    MARK_SOLD: "MARK_SOLD",
    SELL: "MARK_SOLD"
  };
  return alias[token] || "";
}

function normalizeEntityToken_(value) {
  const token = String(value || "").trim().toUpperCase().replace(/[^\w]+/g, "_");
  const alias = {
    MOTOR: "motor",
    KENDARAAN: "motor",
    EXPENSE: "expense",
    PENGELUARAN: "expense",
    AI_MEMORY: "ai_memory",
    MEMORY: "ai_memory"
  };
  return alias[token] || "";
}

function normalizeStatusToken_(value) {
  const token = String(value || "").trim().toUpperCase().replace(/[^\w]+/g, "_");
  if (token === "TERJUAL" || token === "SOLD" || token === "LAKU") return "terjual";
  if (token === "BELUM_TERJUAL" || token === "UNSOLD" || token === "AKTIF" || token === "STOK" || token === "STOCK") return "belum_terjual";
  return "";
}

function splitSearchTokens_(value) {
  const text = normalizeText_(value);
  if (!text) return [];
  return text.split(" ").map(function (v) { return v.trim(); }).filter(function (v) { return v !== ""; });
}

function normalizeDateKey_(value) {
  const raw = String(value || "").trim();
  if (!raw) return "";
  const parsed = parseStructuredRangeDate_(raw);
  if (!parsed) return "";
  const tz = Session.getScriptTimeZone ? Session.getScriptTimeZone() : "Asia/Jakarta";
  return Utilities.formatDate(parsed, tz, "yyyy-MM-dd");
}

function parseStructuredRangeDate_(value) {
  const raw = String(value || "").trim();
  if (!raw) return null;
  const p = parseDate_(raw);
  if (p instanceof Date && !isNaN(p.getTime())) return stripTime_(p);
  const c = parseDateCell_(raw, raw);
  if (c instanceof Date && !isNaN(c.getTime())) return stripTime_(c);
  return null;
}

function pickFirst_(obj, keys) {
  const src = ensureObject_(obj);
  const list = Array.isArray(keys) ? keys : [];
  for (let i = 0; i < list.length; i++) {
    const k = list[i];
    if (src[k] !== undefined && src[k] !== null && String(src[k]).trim() !== "") return src[k];
  }
  return "";
}

function ensureObject_(value) {
  return (value && typeof value === "object" && !Array.isArray(value)) ? value : {};
}

function isFilledValue_(value) {
  if (value === null || value === undefined) return false;
  if (typeof value === "number") return isFinite(value);
  if (value instanceof Date) return !isNaN(value.getTime());
  return String(value).trim() !== "";
}

function routeIncomingMessage_(ctx) {
  const sender = String((ctx && ctx.sender) || "").trim();
  const chatJid = String((ctx && ctx.chatJid) || "").trim();
  const text = String((ctx && ctx.text) || "").trim();
  const lower = String((ctx && ctx.lower) || "").trim();

  let reply = "";
  let saveResult = null;

  const convoKey = buildConversationKey_(sender, chatJid);
  const pendingMotorMasuk = getMotorMasukSession_(convoKey);
  const pendingMotorLaku = getMotorLakuSession_(convoKey);
  const pendingEditHargaJual = getEditHargaJualSession_(convoKey);
  const pendingEditDataMotor = getEditDataMotorSession_(convoKey);
  const pendingDailyExpense = getDailyExpenseSession_(convoKey);

  if (pendingMotorMasuk) {
    const sessionResult = handleMotorMasukSession_(pendingMotorMasuk, text, lower, convoKey);
    return { reply: sessionResult.reply, saveResult: sessionResult.saveResult };
  }

  if (pendingMotorLaku) {
    const sessionResult = handleMotorLakuSession_(pendingMotorLaku, text, lower, convoKey);
    return { reply: sessionResult.reply, saveResult: sessionResult.saveResult };
  }

  if (pendingEditHargaJual) {
    const sessionResult = handleEditHargaJualSession_(pendingEditHargaJual, text, lower, convoKey);
    return { reply: sessionResult.reply, saveResult: sessionResult.saveResult };
  }

  if (pendingEditDataMotor) {
    const sessionResult = handleEditDataMotorSession_(pendingEditDataMotor, text, lower, convoKey);
    return { reply: sessionResult.reply, saveResult: sessionResult.saveResult };
  }

  if (pendingDailyExpense) {
    const sessionResult = handleDailyExpenseSession_(pendingDailyExpense, text, lower, convoKey);
    return { reply: sessionResult.reply, saveResult: sessionResult.saveResult };
  }

  if (isMotorMasukCommand_(text)) {
    clearMotorLakuSession_(convoKey);
    clearEditHargaJualSession_(convoKey);
    clearEditDataMotorSession_(convoKey);
    clearDailyExpenseSession_(convoKey);
    setMotorMasukSession_(convoKey, { stage: "awaiting_details" });
    return {
      reply: [
        "Silakan isi template motor masuk berikut:",
        MOTOR_MASUK_TEMPLATE_TEXT
      ].join("\n\n"),
      saveResult: null
    };
  }

  if (isDailyExpensePromptCommand_(text)) {
    clearMotorMasukSession_(convoKey);
    clearMotorLakuSession_(convoKey);
    clearEditHargaJualSession_(convoKey);
    clearEditDataMotorSession_(convoKey);
    setDailyExpenseSession_(convoKey, { stage: "awaiting_input" });
    return { reply: DAILY_EXPENSE_TEMPLATE_TEXT, saveResult: null };
  }

  if (lower === "halo" || lower === "hi" || lower === "menu") {
    return { reply: getMenuReply_(), saveResult: null };
  }

  const soldKeyword = parseSoldReportKeyword_(text);
  if (soldKeyword !== null) {
    return { reply: findSoldMotorReply_(soldKeyword), saveResult: null };
  }

  const motorLakuCommand = parseMotorLakuCommand_(text);
  if (motorLakuCommand) {
    if (motorLakuCommand.type === "ask_keyword") {
      clearMotorMasukSession_(convoKey);
      clearEditHargaJualSession_(convoKey);
      clearEditDataMotorSession_(convoKey);
      clearDailyExpenseSession_(convoKey);
      setMotorLakuSession_(convoKey, {
        stage: "awaiting_keyword"
      });
      return { reply: "Motor apa?", saveResult: null };
    }

    const motorLakuKeyword = String(motorLakuCommand.keyword || "").trim();
    if (!motorLakuKeyword) {
      return { reply: "Format salah. Gunakan: motor <nama> laku", saveResult: null };
    }

    const options = findActiveMotorRowsByKeyword_(motorLakuKeyword);
    if (!options.length) {
      return { reply: 'Data motor "' + motorLakuKeyword + '" tidak ditemukan.', saveResult: null };
    }

    const shownOptions = options.slice(0, MOTOR_LAKU_LIST_MAX);
    clearMotorMasukSession_(convoKey);
    clearEditHargaJualSession_(convoKey);
    clearEditDataMotorSession_(convoKey);
    clearDailyExpenseSession_(convoKey);
    setMotorLakuSession_(convoKey, {
      stage: "awaiting_selection",
      keyword: motorLakuKeyword,
      options: shownOptions
    });
    return {
      reply: formatMotorLakuOptionsReply_(motorLakuKeyword, shownOptions, options.length),
      saveResult: null
    };
  }

  const editHargaJualKeyword = parseEditHargaJualByNameCommand_(text);
  if (editHargaJualKeyword !== null) {
    if (!editHargaJualKeyword) {
      return { reply: "Format salah. Gunakan: edit harga jual motor <nama>", saveResult: null };
    }

    const options = findActiveMotorRowsByKeyword_(editHargaJualKeyword);
    if (!options.length) {
      return { reply: 'Data motor "' + editHargaJualKeyword + '" tidak ditemukan.', saveResult: null };
    }

    const shownOptions = options.slice(0, MOTOR_LAKU_LIST_MAX);
    clearMotorMasukSession_(convoKey);
    clearMotorLakuSession_(convoKey);
    clearEditDataMotorSession_(convoKey);
    clearDailyExpenseSession_(convoKey);
    setEditHargaJualSession_(convoKey, {
      stage: "awaiting_selection",
      keyword: editHargaJualKeyword,
      options: shownOptions
    });
    return {
      reply: formatEditHargaJualOptionsReply_(editHargaJualKeyword, shownOptions, options.length),
      saveResult: null
    };
  }

  const editDataMotorCommand = parseEditDataMotorCommand_(text);
  if (editDataMotorCommand) {
    if (editDataMotorCommand.type === "ask_keyword") {
      clearMotorMasukSession_(convoKey);
      clearMotorLakuSession_(convoKey);
      clearEditHargaJualSession_(convoKey);
      clearDailyExpenseSession_(convoKey);
      setEditDataMotorSession_(convoKey, { stage: "awaiting_keyword" });
      return { reply: "Motor apa?", saveResult: null };
    }

    const keyword = String(editDataMotorCommand.keyword || "").trim();
    if (!keyword) {
      return { reply: "Format salah. Gunakan: edit data motor <nama>", saveResult: null };
    }

    const options = findAllMotorRowsByKeyword_(keyword);
    if (!options.length) {
      return { reply: 'Data motor "' + keyword + '" tidak ditemukan.', saveResult: null };
    }

    const shownOptions = options.slice(0, MOTOR_LAKU_LIST_MAX);
    clearMotorMasukSession_(convoKey);
    clearMotorLakuSession_(convoKey);
    clearEditHargaJualSession_(convoKey);
    clearDailyExpenseSession_(convoKey);
    setEditDataMotorSession_(convoKey, {
      stage: "awaiting_selection",
      keyword: keyword,
      options: shownOptions
    });
    return {
      reply: formatEditDataMotorOptionsReply_(keyword, shownOptions, options.length),
      saveResult: null
    };
  }

  const expenseCommand = parseExpenseReportCommand_(text);
  if (expenseCommand) {
    return { reply: findExpenseReportReply_(expenseCommand), saveResult: null };
  }

  const profitCommand = parseProfitReportCommand_(text);
  if (profitCommand) {
    return { reply: findProfitReportReply_(profitCommand), saveResult: null };
  }

  const assetModalCommand = parseAssetModalCommand_(text);
  if (assetModalCommand) {
    return { reply: findAssetModalReply_(assetModalCommand), saveResult: null };
  }

  if (lower.startsWith("pengeluaran#")) {
    const body = text.slice("pengeluaran#".length).trim();
    const cols = body.split(";").map(function (s) { return s.trim(); });
    saveResult = saveDailyExpenseData_(cols);
    reply = saveResult.ok
      ? "Pengeluaran harian tersimpan di baris " + saveResult.row
      : "Gagal simpan pengeluaran: " + saveResult.error;
    return { reply: reply, saveResult: saveResult };
  }

  const keyword = parseDataMotorKeyword_(text);
  if (keyword !== null) {
    if (!keyword) {
      return {
        reply: "Format salah. Gunakan: data motor <nama>, cek stok motor <nama>, atau cek motor <nama>",
        saveResult: null
      };
    }
    return { reply: findMotorDataReply_(keyword), saveResult: null };
  }

  if (lower.startsWith("input#")) {
    const body = text.slice(6).trim();
    const rawCols = body.split(";").map(function (s) { return s.trim(); });
    const cols = normalizeInputCols_(rawCols);
    const validation = validateInput_(cols);
    if (!validation.ok) {
      return { reply: "Format salah: " + validation.error, saveResult: null };
    }
    saveResult = saveToSheet_(validation.data);
    reply = saveResult.ok
      ? "Data tersimpan di baris " + saveResult.row
      : "Gagal simpan: " + saveResult.error;
    return { reply: reply, saveResult: saveResult };
  }

  if (lower.startsWith("update#")) {
    const body = text.slice(7).trim();
    const cols = body.split(";").map(function (s) { return s.trim(); });
    saveResult = updateSoldData_(cols);
    reply = saveResult.ok
      ? "Data terupdate di baris " + saveResult.row
      : "Gagal update: " + saveResult.error;
    return { reply: reply, saveResult: saveResult };
  }

  const parsedUpdate = parseLabeledUpdate_(text);
  if (parsedUpdate.matched) {
    saveResult = updateSoldData_(parsedUpdate.cols);
    reply = saveResult.ok
      ? "Data terupdate di baris " + saveResult.row
      : "Gagal update: " + saveResult.error;
    return { reply: reply, saveResult: saveResult };
  }

  const parsed = parseLabeledInput_(text);
  if (parsed.matched) {
    const validation = validateInput_(parsed.cols);
    if (!validation.ok) {
      return { reply: "Format salah: " + validation.error, saveResult: null };
    }
    saveResult = saveToSheet_(validation.data);
    reply = saveResult.ok
      ? "Data tersimpan di baris " + saveResult.row
      : "Gagal simpan: " + saveResult.error;
    return { reply: reply, saveResult: saveResult };
  }

  return { reply: "Perintah tidak dikenali. Ketik HALO untuk lihat format.", saveResult: null };
}

function saveToSheet_(cols) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) {
      return {
        ok: false,
        error: "Spreadsheet tidak terbaca. Isi SPREADSHEET_ID jika script standalone."
      };
    }

    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + SHEET_NAME + '" tidak ditemukan' };

    const row = findFirstEmptyRow_(sh, 2, 2); // cari baris kosong dari kolom B

    const hargaJual = parseNumber_(cols[6]);
    const hargaLaku = parseNumber_(cols[7]);
    const hargaBeli = parseNumber_(cols[8]);
    const tglTerjual = cols[9] ? parseDate_(cols[9]) : "";
    const status = parseStatus_(cols[10], hargaLaku, tglTerjual);
    const suratSurat = normalizeWithValidation_(sh, row, 5, cols[3], "SURAT-SURAT");
    const tahunPlat = normalizeWithValidation_(sh, row, 6, cols[4], "TAHUN PLAT");
    const pajakInput = normalizePajakInput_(cols[5], tahunPlat);
    const pajak = normalizeWithValidation_(sh, row, 7, pajakInput, "PAJAK");

    // Isi data utama
    sh.getRange(row, 2).setValue(cols[0] || "");                 // B NAMA MOTOR
    sh.getRange(row, 3).setValue(cols[1] || "");                 // C TAHUN
    sh.getRange(row, 4).setValue((cols[2] || "").toUpperCase()); // D PLAT
    sh.getRange(row, 5).setValue(suratSurat);                    // E SURAT-SURAT
    sh.getRange(row, 6).setValue(tahunPlat);                     // F TAHUN PLAT
    sh.getRange(row, 7).setValue(pajak);                         // G PAJAK
    sh.getRange(row, 8).setValue(hargaJual);                     // H HARGA JUAL
    sh.getRange(row, 9).setValue(hargaLaku);                     // I HARGA LAKU
    sh.getRange(row, 10).setValue(tglTerjual);                   // J TGL TERJUAL

    // K (LABA/RUGI) tidak diubah dari script karena sudah pakai rumus di spreadsheet
    sh.getRange(row, 12).setValue(hargaBeli);                    // L HARGA BELI
    sh.getRange(row, 13).setValue(status);                       // M STATUS (checkbox)

    // Kolom A (NO) otomatis isi jika kosong, set terakhir agar tidak ada baris setengah jadi saat error
    if (!sh.getRange(row, 1).getValue()) {
      sh.getRange(row, 1).setValue(row - 1);
    }

    log_("SAVE_OK row=" + row + " data=" + JSON.stringify(cols));
    return { ok: true, row: row };
  } catch (err) {
    log_("saveToSheet_ error: " + err.message);
    return { ok: false, error: err.message };
  }
}

function saveDailyExpenseData_(cols) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) {
      return { ok: false, error: "Spreadsheet tidak terbaca." };
    }

    const sh = ss.getSheetByName(EXPENSE_SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + EXPENSE_SHEET_NAME + '" tidak ditemukan' };

    const keterangan = String(cols[0] || "").trim();
    if (!keterangan) {
      return { ok: false, error: "Keterangan wajib diisi." };
    }

    const total = parseNumber_(cols[1]);
    if (typeof total !== "number" || !isFinite(total) || total <= 0) {
      return { ok: false, error: "Total pengeluaran tidak valid." };
    }

    const tanggal = resolveExpenseDate_(cols[2]);
    const map = detectExpenseInputColumns_(sh);
    const row = findFirstEmptyExpenseRow_(sh, 2, map.amountCol);

    sh.getRange(row, map.dateCol).setValue(tanggal);
    sh.getRange(row, map.descCol).setValue(keterangan);
    sh.getRange(row, map.amountCol).setValue(total);

    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function resolveExpenseDate_(value) {
  const raw = String(value || "").trim();
  if (!raw) return new Date();

  const fromParseDate = parseDate_(raw);
  if (fromParseDate instanceof Date && !isNaN(fromParseDate.getTime())) {
    return fromParseDate;
  }

  const fromCell = parseDateCell_(raw, raw);
  if (fromCell instanceof Date && !isNaN(fromCell.getTime())) {
    return fromCell;
  }

  return new Date();
}

function detectExpenseInputColumns_(sheet) {
  const lastCol = Math.max(sheet.getLastColumn(), 3);
  const header = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0] || [];
  const dateIndex = findHeaderIndex_(header, ["tanggal", "tgl", "date"]);
  const descIndex = findHeaderIndex_(header, ["keterangan", "catatan", "deskripsi", "detail", "keperluan"]);
  const amountIndex = findHeaderIndex_(header, ["total pengeluaran", "pengeluaran", "nominal", "jumlah", "biaya", "total", "amount"]);

  return {
    dateCol: dateIndex >= 0 ? (dateIndex + 1) : 1,
    descCol: descIndex >= 0 ? (descIndex + 1) : 2,
    amountCol: amountIndex >= 0 ? (amountIndex + 1) : 3
  };
}

function findFirstEmptyExpenseRow_(sheet, startRow, amountCol) {
  const col = Number(amountCol || 3);
  return findFirstEmptyRow_(sheet, startRow, col);
}

function getSpreadsheet_() {
  if (SPREADSHEET_ID) {
    return SpreadsheetApp.openById(SPREADSHEET_ID);
  }
  return SpreadsheetApp.getActiveSpreadsheet();
}

function findFirstEmptyRow_(sheet, startRow, col) {
  const last = Math.max(sheet.getLastRow(), startRow);
  const vals = sheet.getRange(startRow, col, last - startRow + 1, 1).getValues();
  for (let i = 0; i < vals.length; i++) {
    if (!vals[i][0]) return startRow + i;
  }
  return last + 1;
}

function parseDataMotorKeyword_(text) {
  const raw = String(text || "").trim();
  if (!raw) return null;

  const patterns = [
    /^(?:cek\s+)?data\s+motor(?:\s+(.+))?$/i,
    /^cek\s+stok\s+motor(?:\s+(.+))?$/i,
    /^cek\s+motor(?:\s+(.+))?$/i
  ];

  for (let i = 0; i < patterns.length; i++) {
    const m = raw.match(patterns[i]);
    if (!m) continue;
    return m[1] ? String(m[1]).trim() : "";
  }

  return null;
}

function parseExpenseReportCommand_(text) {
  const normalized = String(text || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();

  if (normalized === "pengeluaran hari ini" || normalized === "cek pengeluaran hari ini") {
    return "today";
  }
  if (normalized === "pengeluaran minggu ini" || normalized === "cek pengeluaran minggu ini") {
    return "last_7_days";
  }
  if (normalized === "pengeluaran bulan ini" || normalized === "cek pengeluaran bulan ini") {
    return "last_30_days";
  }
  return "";
}

function parseProfitReportCommand_(text) {
  const normalized = String(text || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();

  if (
    normalized === "laba hari ini" ||
    normalized === "cek laba hari ini" ||
    normalized === "keuntungan hari ini" ||
    normalized === "cek keuntungan hari ini"
  ) {
    return "today";
  }

  if (
    normalized === "laba minggu ini" ||
    normalized === "cek laba minggu ini" ||
    normalized === "keuntungan minggu ini" ||
    normalized === "cek keuntungan minggu ini" ||
    normalized === "keuntungan mingu ini" ||
    normalized === "cek keuntungan mingu ini"
  ) {
    return "last_7_days";
  }

  if (
    normalized === "laba bulan ini" ||
    normalized === "cek laba bulan ini" ||
    normalized === "keuntungan bulan ini" ||
    normalized === "cek keuntungan bulan ini"
  ) {
    return "last_30_days";
  }

  return "";
}

function parseAssetModalCommand_(text) {
  const normalized = String(text || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();

  if (normalized === "total aset kendaraan" || normalized === "total kendaraan") {
    return "aset_kendaraan";
  }

  if (normalized === "total modal" || normalized === "total modal sekarang") {
    return "modal_sekarang";
  }

  return "";
}

function findExpenseReportReply_(scope) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return "Spreadsheet tidak terbaca.";

    const sh = ss.getSheetByName(EXPENSE_SHEET_NAME);
    if (!sh) return 'Sheet "' + EXPENSE_SHEET_NAME + '" tidak ditemukan';

    const rangeInfo = getExpenseDateRange_(scope);
    const startRow = 2;
    const last = sh.getLastRow();
    if (last < startRow) {
      return rangeInfo.emptyReply;
    }

    const lastCol = Math.max(sh.getLastColumn(), 1);
    const header = sh.getRange(1, 1, 1, lastCol).getDisplayValues()[0] || [];
    const columnMap = detectExpenseColumns_(header);
    const rowCount = last - startRow + 1;
    const rawVals = sh.getRange(startRow, 1, rowCount, lastCol).getValues();
    const displayVals = sh.getRange(startRow, 1, rowCount, lastCol).getDisplayValues();

    const rows = [];
    let total = 0;

    for (let i = 0; i < displayVals.length; i++) {
      const picked = extractExpenseRow_(rawVals[i], displayVals[i], columnMap);
      if (!picked.date) continue;

      const rowDate = stripTime_(picked.date);
      if (rowDate.getTime() < rangeInfo.start.getTime() || rowDate.getTime() > rangeInfo.end.getTime()) {
        continue;
      }

      if (picked.amount === null || !isFinite(picked.amount) || picked.amount <= 0) {
        continue;
      }

      total += picked.amount;
      rows.push({
        date: rowDate,
        description: picked.description || "-",
        amount: picked.amount
      });
    }

    if (!rows.length) {
      return rangeInfo.emptyReply;
    }

    rows.sort(function (a, b) {
      return a.date.getTime() - b.date.getTime();
    });

    const lines = [rangeInfo.title + ":"];
    for (let i = 0; i < rows.length; i++) {
      lines.push(
        (i + 1) + ". " +
        formatDateForReport_(rows[i].date) + " | " +
        rows[i].description + " | Rp" + formatRupiah_(rows[i].amount)
      );
    }
    lines.push("");
    lines.push("Total: Rp" + formatRupiah_(total));
    lines.push("Jumlah data: " + rows.length);
    return lines.join("\n");
  } catch (err) {
    return "Gagal ambil laporan pengeluaran: " + err.message;
  }
}

function findProfitReportReply_(scope) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return "Spreadsheet tidak terbaca.";

    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return 'Sheet "' + SHEET_NAME + '" tidak ditemukan';

    const rangeInfo = getProfitDateRange_(scope);
    const startRow = 2;
    const last = sh.getLastRow();
    if (last < startRow) {
      return rangeInfo.emptyReply;
    }

    const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
    const rawVals = range.getValues();
    const displayVals = range.getDisplayValues();
    const rows = [];
    let total = 0;

    for (let i = 0; i < rawVals.length; i++) {
      const rawRow = rawVals[i];
      const displayRow = displayVals[i];
      const soldDate = parseDateCell_(rawRow[9], displayRow[9]); // J TGL TERJUAL
      if (!soldDate) continue;

      const soldDay = stripTime_(soldDate);
      if (soldDay.getTime() < rangeInfo.start.getTime() || soldDay.getTime() > rangeInfo.end.getTime()) {
        continue;
      }

      const profit = parseProfitValue_(rawRow[10], displayRow[10]); // K LABA/RUGI
      if (profit === null || !isFinite(profit)) continue;

      total += profit;
      rows.push({
        no: displayCell_(displayRow[0]),
        nama: displayCell_(displayRow[1]),
        plat: displayCell_(displayRow[3]),
        soldDate: soldDay,
        profit: profit
      });
    }

    if (!rows.length) {
      return rangeInfo.emptyReply;
    }

    rows.sort(function (a, b) {
      return a.soldDate.getTime() - b.soldDate.getTime();
    });

    const lines = [rangeInfo.title + ":"];
    for (let i = 0; i < rows.length; i++) {
      lines.push(
        (i + 1) + ". " +
        formatDateForReport_(rows[i].soldDate) +
        " | NO " + rows[i].no +
        " | " + rows[i].nama +
        " | " + rows[i].plat +
        " | " + formatSignedRupiah_(rows[i].profit)
      );
    }
    lines.push("");
    lines.push("Total bersih: " + formatSignedRupiah_(total));
    lines.push("Jumlah data: " + rows.length);
    return lines.join("\n");
  } catch (err) {
    return "Gagal ambil laporan laba/rugi: " + err.message;
  }
}

function findAssetModalReply_(scope) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) return "Spreadsheet tidak terbaca.";

    if (scope === "aset_kendaraan") {
      const asetSheet = ss.getSheetByName(TOTAL_ASET_SHEET_NAME);
      if (!asetSheet) return 'Sheet "' + TOTAL_ASET_SHEET_NAME + '" tidak ditemukan';

      const stockSheet = ss.getSheetByName(SHEET_NAME);
      if (!stockSheet) return 'Sheet "' + SHEET_NAME + '" tidak ditemukan';

      const asetValue = readNamedMetricFromSheet_(asetSheet, [
        "total aset kendaraan"
      ]);
      const totalUnits = countActiveVehicleUnits_(stockSheet);

      const lines = [
        "Laporan aset kendaraan:",
        "Total aset kendaraan: " + formatMaybeCurrency_(asetValue),
        "Total jumlah kendaraan (stok aktif): " + totalUnits + " unit"
      ];
      return lines.join("\n");
    }

    if (scope === "modal_sekarang") {
      const asetSheet = ss.getSheetByName(TOTAL_ASET_SHEET_NAME);
      if (!asetSheet) return 'Sheet "' + TOTAL_ASET_SHEET_NAME + '" tidak ditemukan';

      const modalValue = readNamedMetricFromSheet_(asetSheet, [
        "total modal sekarang",
        "total modal"
      ]);

      return [
        "Laporan modal:",
        "Total modal sekarang: " + formatMaybeCurrency_(modalValue)
      ].join("\n");
    }

    return "Perintah tidak dikenali.";
  } catch (err) {
    return "Gagal ambil laporan aset/modal: " + err.message;
  }
}

function readNamedMetricFromSheet_(sheet, labelCandidates) {
  const lastRow = Math.max(sheet.getLastRow(), 1);
  const lastCol = Math.max(sheet.getLastColumn(), 1);
  const rawVals = sheet.getRange(1, 1, lastRow, lastCol).getValues();
  const displayVals = sheet.getRange(1, 1, lastRow, lastCol).getDisplayValues();
  const labels = Array.isArray(labelCandidates) ? labelCandidates : [];

  for (let r = 0; r < displayVals.length; r++) {
    for (let c = 0; c < displayVals[r].length; c++) {
      const cellText = normalizeText_(displayVals[r][c]);
      if (!cellText) continue;
      if (!matchesAnyLabel_(cellText, labels)) continue;

      const found = findNearestNumericValue_(rawVals, displayVals, r, c);
      if (found !== null) return found;
    }
  }

  return null;
}

function matchesAnyLabel_(cellText, labels) {
  for (let i = 0; i < labels.length; i++) {
    if (cellText.indexOf(normalizeText_(labels[i])) !== -1) return true;
  }
  return false;
}

function findNearestNumericValue_(rawVals, displayVals, r, c) {
  const positions = [
    [r, c + 1],
    [r + 1, c],
    [r, c + 2],
    [r + 2, c],
    [r + 1, c + 1]
  ];

  for (let i = 0; i < positions.length; i++) {
    const rr = positions[i][0];
    const cc = positions[i][1];
    if (rr < 0 || cc < 0) continue;
    if (rr >= rawVals.length) continue;
    if (cc >= rawVals[rr].length) continue;

    const n = toNumberOrNull_(rawVals[rr][cc], displayVals[rr][cc]);
    if (n !== null) return n;
  }

  return null;
}

function toNumberOrNull_(rawValue, displayValue) {
  if (typeof rawValue === "number" && isFinite(rawValue)) {
    return rawValue;
  }
  const parsed = parseNumber_(displayValue !== undefined ? displayValue : rawValue);
  if (typeof parsed === "number" && isFinite(parsed)) {
    return parsed;
  }
  return null;
}

function countActiveVehicleUnits_(sheet) {
  const startRow = 2;
  const last = sheet.getLastRow();
  if (last < startRow) return 0;

  const range = sheet.getRange(startRow, 1, last - startRow + 1, 13);
  const rawVals = range.getValues();
  const displayVals = range.getDisplayValues();

  let count = 0;
  for (let i = 0; i < rawVals.length; i++) {
    const row = displayVals[i];
    const rawRow = rawVals[i];
    const nama = normalizeText_(row[1]);
    const plat = normalizeText_(row[3]);
    if (!nama && !plat) continue;
    if (isSoldStatusValue_(rawRow, row)) continue;
    count++;
  }

  return count;
}

function formatMaybeCurrency_(value) {
  if (value === null || value === undefined || value === "") return "-";
  if (typeof value === "number" && isFinite(value)) {
    return "Rp" + formatRupiah_(value);
  }
  const n = parseNumber_(value);
  if (typeof n === "number" && isFinite(n)) {
    return "Rp" + formatRupiah_(n);
  }
  return String(value);
}

function getExpenseDateRange_(scope) {
  const today = stripTime_(new Date());
  if (scope === "today") {
    return {
      start: today,
      end: today,
      title: "Laporan pengeluaran hari ini (" + formatDateForReport_(today) + ")",
      emptyReply: "Belum ada data pengeluaran hari ini."
    };
  }

  if (scope === "last_7_days") {
    const start7 = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 7);
    return {
      start: start7,
      end: today,
      title: "Laporan pengeluaran minggu ini (" + formatDateForReport_(start7) + " s/d " + formatDateForReport_(today) + ")",
      emptyReply: "Belum ada data pengeluaran untuk 7 hari terakhir."
    };
  }

  const start = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 30);
  return {
    start: start,
    end: today,
    title: "Laporan pengeluaran bulan ini (" + formatDateForReport_(start) + " s/d " + formatDateForReport_(today) + ")",
    emptyReply: "Belum ada data pengeluaran untuk 30 hari terakhir."
  };
}

function getProfitDateRange_(scope) {
  const today = stripTime_(new Date());
  if (scope === "today") {
    return {
      start: today,
      end: today,
      title: "Laporan laba/rugi hari ini (" + formatDateForReport_(today) + ")",
      emptyReply: "Belum ada data laba/rugi hari ini."
    };
  }

  if (scope === "last_7_days") {
    const start7 = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 7);
    return {
      start: start7,
      end: today,
      title: "Laporan laba/rugi minggu ini (" + formatDateForReport_(start7) + " s/d " + formatDateForReport_(today) + ")",
      emptyReply: "Belum ada data laba/rugi untuk 7 hari terakhir."
    };
  }

  const start30 = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 30);
  return {
    start: start30,
    end: today,
    title: "Laporan laba/rugi bulan ini (" + formatDateForReport_(start30) + " s/d " + formatDateForReport_(today) + ")",
    emptyReply: "Belum ada data laba/rugi untuk 30 hari terakhir."
  };
}

function detectExpenseColumns_(headerRow) {
  const headers = Array.isArray(headerRow) ? headerRow : [];
  return {
    dateIndex: findHeaderIndex_(headers, ["tanggal", "tgl", "date"]),
    amountIndex: findHeaderIndex_(headers, ["nominal", "jumlah", "pengeluaran", "biaya", "total", "amount"]),
    descIndex: findHeaderIndex_(headers, ["keterangan", "catatan", "deskripsi", "detail", "keperluan"])
  };
}

function findHeaderIndex_(headers, keywords) {
  const keys = Array.isArray(keywords) ? keywords : [];
  for (let i = 0; i < headers.length; i++) {
    const h = normalizeText_(headers[i]);
    if (!h) continue;
    for (let j = 0; j < keys.length; j++) {
      if (h.indexOf(keys[j]) !== -1) return i;
    }
  }
  return -1;
}

function extractExpenseRow_(rawRow, displayRow, columnMap) {
  const raw = Array.isArray(rawRow) ? rawRow : [];
  const disp = Array.isArray(displayRow) ? displayRow : [];
  const map = columnMap || {};

  let date = null;
  let dateIndex = map.dateIndex;

  if (dateIndex >= 0 && dateIndex < raw.length) {
    date = parseDateCell_(raw[dateIndex], disp[dateIndex]);
  }
  if (!date) {
    for (let i = 0; i < raw.length; i++) {
      const guessed = parseDateCell_(raw[i], disp[i]);
      if (guessed) {
        date = guessed;
        dateIndex = i;
        break;
      }
    }
  }

  let amount = null;
  let amountIndex = map.amountIndex;

  if (amountIndex >= 0 && amountIndex < raw.length) {
    amount = parseAmountCell_(raw[amountIndex], disp[amountIndex]);
  }
  if (amount === null) {
    for (let i = raw.length - 1; i >= 0; i--) {
      if (i === dateIndex) continue;
      const guessed = parseAmountCell_(raw[i], disp[i]);
      if (guessed !== null && guessed > 0) {
        amount = guessed;
        amountIndex = i;
        break;
      }
    }
  }

  let description = "";
  const descIndex = map.descIndex;
  if (descIndex >= 0 && descIndex < disp.length) {
    description = String(disp[descIndex] || "").trim();
  }
  if (!description) {
    for (let i = 0; i < disp.length; i++) {
      if (i === dateIndex || i === amountIndex) continue;
      const text = String(disp[i] || "").trim();
      if (!text) continue;
      if (parseDateCell_(raw[i], disp[i])) continue;
      if (parseAmountCell_(raw[i], disp[i]) !== null) continue;
      description = text;
      break;
    }
  }

  return {
    date: date,
    amount: amount,
    description: description
  };
}

function parseDateCell_(rawValue, displayValue) {
  if (rawValue instanceof Date && !isNaN(rawValue.getTime())) {
    return stripTime_(rawValue);
  }

  const text = String(displayValue || rawValue || "").trim();
  if (!text) return null;

  let m = text.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})$/);
  if (m) {
    let year = Number(m[3]);
    if (year < 100) year = year + 2000;
    const d = new Date(year, Number(m[2]) - 1, Number(m[1]));
    return isNaN(d.getTime()) ? null : stripTime_(d);
  }

  m = text.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
  if (m) {
    const d = new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
    return isNaN(d.getTime()) ? null : stripTime_(d);
  }

  return null;
}

function parseAmountCell_(rawValue, displayValue) {
  if (typeof rawValue === "number" && isFinite(rawValue)) {
    return rawValue;
  }

  const parsed = parseNumber_(displayValue !== undefined ? displayValue : rawValue);
  if (typeof parsed === "number" && isFinite(parsed)) {
    return parsed;
  }
  return null;
}

function parseProfitValue_(rawValue, displayValue) {
  if (typeof rawValue === "number" && isFinite(rawValue)) {
    return rawValue;
  }

  const parsed = parseNumber_(displayValue !== undefined ? displayValue : rawValue);
  if (typeof parsed === "number" && isFinite(parsed)) {
    return parsed;
  }
  return null;
}

function stripTime_(dateObj) {
  if (!(dateObj instanceof Date) || isNaN(dateObj.getTime())) return null;
  return new Date(dateObj.getFullYear(), dateObj.getMonth(), dateObj.getDate());
}

function formatDateForReport_(dateObj) {
  const tz = Session.getScriptTimeZone ? Session.getScriptTimeZone() : "Asia/Jakarta";
  return Utilities.formatDate(dateObj, tz, "dd/MM/yyyy");
}

function formatRupiah_(value) {
  const n = Math.round(Number(value) || 0);
  const sign = n < 0 ? "-" : "";
  const abs = Math.abs(n);
  return sign + String(abs).replace(/\B(?=(\d{3})+(?!\d))/g, ".");
}

function formatSignedRupiah_(value) {
  const n = Math.round(Number(value) || 0);
  if (n > 0) return "+Rp" + formatRupiah_(n);
  if (n < 0) return "-Rp" + formatRupiah_(Math.abs(n));
  return "Rp0";
}

function getMenuReply_() {
  return [
    "Menu Bot Arjun Motor:",
    "",
    "1. Motor masuk (2 tahap)",
    "motor masuk",
    "",
    "2. Motor laku (pilih dari daftar)",
    "motor <nama> laku",
    "motor laku <nama>",
    "motor terjual <nama>",
    "motor <nama> terjual",
    "motor laku",
    "motor terjual",
    "ada motor laku",
    "ada motor terjual",
    "no <pilihan> laku <harga>",
    "<pilihan> <harga> (format singkat)",
    "OK / BATAL",
    "",
    "3. Cek stok motor",
    "data motor <nama>",
    "cek data motor <nama>",
    "cek stok motor <nama>",
    "cek motor <nama>",
    "",
    "4. Cek motor terjual",
    "data motor yang sudah terjual",
    "data motor yang sudah laku",
    "cek data motor yang sudah terjual",
    "cek data motor yang sudah laku",
    "cek motor yang sudah laku",
    "cek motor yang sudah terjual",
    "data motor <nama> yang sudah terjual",
    "data motor <nama> yang sudah laku",
    "cek data motor <nama> yang sudah terjual",
    "cek data motor <nama> yang sudah laku",
    "cek motor <nama> yang sudah laku",
    "cek motor <nama> yang sudah terjual",
    "motor <nama> yang sudah laku",
    "motor <nama> yang sudah terjual",
    "",
    "5. Laporan pengeluaran",
    "pengeluaran hari ini",
    "cek pengeluaran hari ini",
    "pengeluaran minggu ini",
    "cek pengeluaran minggu ini",
    "pengeluaran bulan ini",
    "cek pengeluaran bulan ini",
    "",
    "6. Laporan laba/rugi",
    "laba hari ini / cek laba hari ini",
    "keuntungan hari ini / cek keuntungan hari ini",
    "laba minggu ini / cek laba minggu ini",
    "keuntungan minggu ini / cek keuntungan minggu ini",
    "laba bulan ini / cek laba bulan ini",
    "keuntungan bulan ini / cek keuntungan bulan ini",
    "",
    "7. Laporan aset & modal",
    "total aset kendaraan / total kendaraan",
    "total modal / total modal sekarang",
    "",
    "8. Notifikasi pengeluaran harian",
    "otomatis jam 22:00 (default)",
    "manual input: pengeluaran / pengeluaran harian / pengeluaran hari ini",
    "untuk report tetap pakai: cek pengeluaran hari ini",
    "manual test trigger: trigger pengeluaran harian",
    "balas template:",
    "- keterangan :",
    "- total pengeluaran :",
    "",
    "9. Input cepat (opsional)",
    "input#nama motor;tahun;plat;surat-surat;tahun plat;pajak;harga jual;harga beli",
    "",
    "10. Update cepat (opsional)",
    "update#no;harga jual;harga laku;tgl terjual;status",
    "",
    "11. Edit harga jual",
    "edit harga jual motor <nama>",
    "edit harga jual <nama>",
    "balasan: no <no> <harga> atau <no> <harga>",
    "pakai urutan list: pilih <urutan> <harga>",
    "",
    "12. Edit data motor",
    "edit data motor <nama>",
    "edit data motor",
    "jika diminta: balas nama motor (contoh: shogun / motor shogun)",
    "pilih data: nomor <urutan> / no <no> / pilih <urutan>",
    "kirim ulang template yang sudah diedit, lalu OK / BATAL"
  ].join("\n");
}

function parseSoldReportKeyword_(text) {
  const raw = String(text || "").trim();
  if (!raw) return null;

  const m = raw.match(/^(?:cek\s+)?(?:data\s+)?motor(?:\s+(.+?))?\s+yang\s+sudah\s+(?:terjual|laku)$/i);
  if (!m) return null;
  return m[1] ? String(m[1]).trim() : "";

}

function findSoldMotorReply_(keyword) {
  try {
    const q = normalizeText_(keyword);
    const hasKeyword = Boolean(q);

    const ss = getSpreadsheet_();
    if (!ss) return "Spreadsheet tidak terbaca.";

    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return 'Sheet "' + SHEET_NAME + '" tidak ditemukan';

    const startRow = 2;
    const last = sh.getLastRow();
    if (last < startRow) {
      return hasKeyword
        ? 'Data motor terjual "' + keyword + '" tidak ditemukan.'
        : "Belum ada motor terjual.";
    }

    const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
    const displayVals = range.getDisplayValues();
    const rawVals = range.getValues();
    const rows = [];

    for (let i = 0; i < displayVals.length; i++) {
      const row = displayVals[i];
      const rawRow = rawVals[i];
      const namaMotor = normalizeText_(row[1]); // kolom B
      if (!namaMotor) continue;
      if (hasKeyword && namaMotor.indexOf(q) === -1) continue;
      if (!isSoldStatusValue_(rawRow, row)) continue;
      rows.push(formatSoldMotorRow_(row));
    }

    if (!rows.length) {
      return hasKeyword
        ? 'Data motor terjual "' + keyword + '" tidak ditemukan.'
        : "Belum ada motor terjual.";
    }

    return hasKeyword
      ? ('Ditemukan ' + rows.length + ' motor terjual "' + keyword + '":\n\n' + rows.join("\n\n"))
      : ('Ditemukan ' + rows.length + " motor terjual:\n\n" + rows.join("\n\n"));
  } catch (err) {
    return "Gagal ambil data motor terjual: " + err.message;
  }
}

function findMotorDataReply_(keyword) {
  try {
    const q = normalizeText_(keyword);
    if (!q) return "Format salah. Gunakan: data motor <nama>, cek stok motor <nama>, atau cek motor <nama>";

    const ss = getSpreadsheet_();
    if (!ss) return "Spreadsheet tidak terbaca.";

    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return 'Sheet "' + SHEET_NAME + '" tidak ditemukan';

    const startRow = 2;
    const last = sh.getLastRow();
    if (last < startRow) {
      return 'Data motor "' + keyword + '" tidak ditemukan.';
    }

    const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
    const vals = range.getDisplayValues();
    const rawVals = range.getValues();
    const rows = [];

    for (let i = 0; i < vals.length; i++) {
      const row = vals[i];
      const rawRow = rawVals[i];
      const namaMotor = normalizeText_(row[1]); // kolom B
      if (!namaMotor) continue;
      if (namaMotor.indexOf(q) === -1) continue;
      if (isSoldStatusValue_(rawRow, row)) continue; // stok aktif saja (belum terjual)
      rows.push(formatMotorRow_(row));
    }

    if (!rows.length) {
      return 'Data motor "' + keyword + '" tidak ditemukan.';
    }

    return (
      'Ditemukan ' + rows.length + ' data motor "' + keyword + '":\n\n' +
      rows.join("\n\n")
    );
  } catch (err) {
    return "Gagal ambil data motor: " + err.message;
  }
}

function formatSoldMotorRow_(row) {
  return [
    "NO: " + displayCell_(row[0]),         // A
    "NAMA MOTOR: " + displayCell_(row[1]), // B
    "TAHUN: " + displayCell_(row[2]),      // C
    "PLAT: " + displayCell_(row[3]),       // D
    "HARGA LAKU: " + displayCell_(row[8]), // I
    "TGL TERJUAL: " + displayCell_(row[9]) // J
  ].join("\n");
}

function formatMotorRow_(row) {
  return [
    "NO: " + displayCell_(row[0]),          // A
    "NAMA MOTOR: " + displayCell_(row[1]),  // B
    "TAHUN: " + displayCell_(row[2]),       // C
    "PLAT: " + displayCell_(row[3]),        // D
    "SURAT-SURAT: " + displayCell_(row[4]), // E
    "TAHUN PLAT: " + displayCell_(row[5]),  // F
    "PAJAK: " + displayCell_(row[6]),       // G
    "HARGA JUAL: " + displayCell_(row[7]),  // H
    "HARGA BELI: " + displayCell_(row[11])  // L
  ].join("\n");
}

function displayCell_(value) {
  const s = String(value === undefined || value === null ? "" : value).trim();
  return s || "-";
}

function isSoldStatusValue_(rawRow, displayRow) {
  const rawStatus = rawRow && rawRow.length > 12 ? rawRow[12] : "";
  if (rawStatus === true) return true;

  const statusText = normalizeText_(displayRow && displayRow.length > 12 ? displayRow[12] : "");
  if (["true", "1", "ya", "yes", "terjual", "laku", "sold", "done"].indexOf(statusText) !== -1) {
    return true;
  }

  const rawHargaLaku = rawRow && rawRow.length > 8 ? rawRow[8] : "";
  const rawTglTerjual = rawRow && rawRow.length > 9 ? rawRow[9] : "";
  return isFilledValue_(rawHargaLaku) || isFilledValue_(rawTglTerjual);
}

function parseDate_(s) {
  const m = String(s).match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
  if (!m) return s; // kalau bukan format tanggal, simpan sebagai teks
  return new Date(Number(m[3]), Number(m[2]) - 1, Number(m[1]));
}

function parseNumber_(value) {
  const raw = String(value || "").trim();
  if (!raw) return "";
  const cleaned = raw.replace(/\./g, "").replace(",", ".").replace(/[^\d\-\.]/g, "");
  const n = Number(cleaned);
  return isNaN(n) ? raw : n;
}

function parseStatus_(statusText, hargaLaku, tglTerjual) {
  // Jika harga laku terisi, status selalu dianggap terjual (centang).
  if (isFilledValue_(hargaLaku)) {
    return true;
  }

  const s = String(statusText || "").trim().toLowerCase();
  if (!s) {
    return isFilledValue_(tglTerjual);
  }
  return ["1", "true", "ya", "yes", "terjual", "laku", "sold", "done"].indexOf(s) !== -1;
}

function isFilledValue_(value) {
  if (value === null || value === undefined) return false;
  if (value instanceof Date) return !isNaN(value.getTime());
  if (typeof value === "number") return true;
  return String(value).trim() !== "";
}

function validateInput_(cols) {
  const normalized = cols.slice();

  // SURAT-SURAT opsional; jika diisi harus sesuai pilihan yang diizinkan.
  const suratRaw = String(cols[3] || "").trim();
  if (suratRaw) {
    const surat = normalizeSurat_(suratRaw);
    if (!surat) {
      return { ok: false, error: 'SURAT-SURAT harus "Lengkap hidup", "Lengkap mati", atau "BPKB ONLY".' };
    }
    normalized[3] = surat;
  }

  return { ok: true, data: normalized };
}

function normalizeSurat_(value) {
  const v = String(value || "").trim().toLowerCase();
  if (v === "lengkap hidup") return "Lengkap hidup";
  if (v === "lengkap mati") return "Lengkap mati";
  if (v === "bpkb only") return "BPKB ONLY";
  return "";
}

function normalizeInputCols_(rawCols) {
  const cols = rawCols.slice();

  // Format singkat lama:
  // input#nama motor;tahun;plat;surat-surat;tahun plat;pajak;harga beli
  if (cols.length === 7) {
    return [
      cols[0], cols[1], cols[2], cols[3], cols[4], cols[5],
      "", "", cols[6], "", ""
    ];
  }

  // Format singkat baru:
  // input#nama motor;tahun;plat;surat-surat;tahun plat;pajak;harga jual;harga beli
  if (cols.length === 8) {
    return [
      cols[0], cols[1], cols[2], cols[3], cols[4], cols[5],
      cols[6], "", cols[7], "", ""
    ];
  }

  while (cols.length < 11) cols.push("");
  return cols.slice(0, 11);
}

function normalizePajakInput_(value, tahunPlat) {
  const raw = String(value || "").trim();
  const v = raw.toLowerCase();
  if (!v) return "";

  // Jika input pajak berupa status, konversi ke angka tahun agar cocok dengan dropdown tahun.
  if (["hidup", "aktif", "on", "yes", "lunas"].indexOf(v) !== -1) {
    const y = extractYear_(tahunPlat) || new Date().getFullYear();
    return String(y);
  }
  if (["mati", "off", "no", "telat", "belum"].indexOf(v) !== -1) {
    const y = extractYear_(tahunPlat);
    if (y) return String(y - 1);
    return String(new Date().getFullYear() - 1);
  }

  return raw;
}

function normalizeWithValidation_(sheet, row, col, value, fieldName) {
  const raw = String(value || "").trim();
  if (!raw) return "";

  const range = sheet.getRange(row, col);
  const options = getValidationOptions_(range);

  // Jika tidak ada data validation, simpan apa adanya
  if (!options.length) return raw;

  // Cocokkan exact (case-insensitive)
  const target = normalizeText_(raw);
  for (let i = 0; i < options.length; i++) {
    if (normalizeText_(options[i]) === target) return options[i];
  }

  // Cocokkan parsial untuk nilai seperti "pajak hidup" vs "Hidup"
  for (let i = 0; i < options.length; i++) {
    const opt = normalizeText_(options[i]);
    if (opt.indexOf(target) !== -1 || target.indexOf(opt) !== -1) return options[i];
  }

  throw new Error(fieldName + " tidak valid. Pilihan yang tersedia: " + options.join(" / "));
}

function getValidationOptions_(range) {
  const rule = range.getDataValidation();
  if (!rule) return [];

  const type = rule.getCriteriaType();
  const args = rule.getCriteriaValues();

  if (type === SpreadsheetApp.DataValidationCriteria.VALUE_IN_LIST) {
    return (args[0] || [])
      .map(function (v) { return String(v).trim(); })
      .filter(function (v) { return v !== ""; });
  }

  if (type === SpreadsheetApp.DataValidationCriteria.VALUE_IN_RANGE) {
    const sourceRange = args[0];
    if (!sourceRange) return [];
    return sourceRange.getDisplayValues()
      .reduce(function (acc, rowVals) { return acc.concat(rowVals); }, [])
      .map(function (v) { return String(v).trim(); })
      .filter(function (v) { return v !== ""; });
  }

  return [];
}

function normalizeText_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();
}

function extractYear_(value) {
  const m = String(value || "").match(/\b(19|20)\d{2}\b/);
  return m ? Number(m[0]) : null;
}

function updateSoldData_(cols) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) {
      return { ok: false, error: "Spreadsheet tidak terbaca." };
    }
    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + SHEET_NAME + '" tidak ditemukan' };

    const noInput = String(cols[0] || "").trim();
    if (!noInput) return { ok: false, error: "NO wajib diisi untuk update." };

    const row = findRowByNo_(sh, noInput);
    if (!row) return { ok: false, error: "NO tidak ditemukan: " + noInput };

    const hargaJual = String(cols[1] || "").trim() ? parseNumber_(cols[1]) : null;
    const hasHargaLaku = String(cols[2] || "").trim() !== "";
    const hargaLaku = hasHargaLaku ? parseNumber_(cols[2]) : null;
    let tglTerjual = String(cols[3] || "").trim() ? parseDate_(cols[3]) : null;

    // Jika harga laku diupdate tapi tanggal kosong, isi otomatis dengan tanggal hari ini.
    if (!tglTerjual && hasHargaLaku) {
      tglTerjual = new Date();
    }

    if (hargaJual !== null) sh.getRange(row, 8).setValue(hargaJual); // H HARGA JUAL
    if (hargaLaku !== null) sh.getRange(row, 9).setValue(hargaLaku); // I HARGA LAKU
    if (tglTerjual !== null) sh.getRange(row, 10).setValue(tglTerjual); // J TGL TERJUAL

    const currentHargaLaku = hargaLaku !== null ? hargaLaku : sh.getRange(row, 9).getValue();
    const currentTglTerjual = tglTerjual !== null ? tglTerjual : sh.getRange(row, 10).getValue();
    const status = parseStatus_(cols[4], currentHargaLaku, currentTglTerjual);
    sh.getRange(row, 13).setValue(status); // M STATUS

    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function updateMotorDataByNo_(noInput, cols) {
  try {
    const ss = getSpreadsheet_();
    if (!ss) {
      return { ok: false, error: "Spreadsheet tidak terbaca." };
    }
    const sh = ss.getSheetByName(SHEET_NAME);
    if (!sh) return { ok: false, error: 'Sheet "' + SHEET_NAME + '" tidak ditemukan' };

    const no = normalizeNo_(noInput);
    if (!no) return { ok: false, error: "NO wajib diisi untuk edit data motor." };

    const row = findRowByNo_(sh, no);
    if (!row) return { ok: false, error: "NO tidak ditemukan: " + no };

    const list = Array.isArray(cols) ? cols : [];
    const currentRaw = sh.getRange(row, 1, 1, 13).getValues()[0] || [];
    const currentDisplay = sh.getRange(row, 1, 1, 13).getDisplayValues()[0] || [];

    const namaMotor = hasInputValue_(list[0]) ? String(list[0] || "").trim() : String(currentDisplay[1] || "").trim();
    const tahun = hasInputValue_(list[1]) ? String(list[1] || "").trim() : String(currentDisplay[2] || "").trim();
    const plat = hasInputValue_(list[2]) ? String(list[2] || "").trim().toUpperCase() : String(currentDisplay[3] || "").trim().toUpperCase();
    const suratInput = hasInputValue_(list[3]) ? list[3] : currentDisplay[4];
    const tahunPlatInput = hasInputValue_(list[4]) ? list[4] : currentDisplay[5];
    const pajakSource = hasInputValue_(list[5]) ? list[5] : currentDisplay[6];

    const suratSurat = normalizeWithValidation_(sh, row, 5, suratInput, "SURAT-SURAT");
    const tahunPlat = normalizeWithValidation_(sh, row, 6, tahunPlatInput, "TAHUN PLAT");
    const pajakInput = normalizePajakInput_(pajakSource, tahunPlat);
    const pajak = normalizeWithValidation_(sh, row, 7, pajakInput, "PAJAK");

    const hargaJual = hasInputValue_(list[6]) ? parseNumber_(list[6]) : currentRaw[7];
    const hargaLaku = hasInputValue_(list[7]) ? parseNumber_(list[7]) : currentRaw[8];
    const hargaBeli = hasInputValue_(list[8]) ? parseNumber_(list[8]) : currentRaw[11];
    const tglTerjual = hasInputValue_(list[9]) ? parseDate_(list[9]) : currentRaw[9];
    const statusInput = hasInputValue_(list[10]) ? list[10] : currentRaw[12];
    const status = parseStatus_(statusInput, hargaLaku, tglTerjual);

    sh.getRange(row, 2).setValue(namaMotor);  // B NAMA MOTOR
    sh.getRange(row, 3).setValue(tahun);      // C TAHUN
    sh.getRange(row, 4).setValue(plat);       // D PLAT
    sh.getRange(row, 5).setValue(suratSurat); // E SURAT-SURAT
    sh.getRange(row, 6).setValue(tahunPlat);  // F TAHUN PLAT
    sh.getRange(row, 7).setValue(pajak);      // G PAJAK
    sh.getRange(row, 8).setValue(hargaJual);  // H HARGA JUAL
    sh.getRange(row, 9).setValue(hargaLaku);  // I HARGA LAKU
    sh.getRange(row, 10).setValue(tglTerjual);// J TGL TERJUAL
    sh.getRange(row, 12).setValue(hargaBeli); // L HARGA BELI
    sh.getRange(row, 13).setValue(status);    // M STATUS

    if (!sh.getRange(row, 1).getValue()) {
      sh.getRange(row, 1).setValue(row - 1);
    }

    return { ok: true, row: row };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

function findRowByNo_(sheet, noInput) {
  const target = normalizeNo_(noInput);
  if (target === "") return 0;

  const startRow = 2;
  const last = Math.max(sheet.getLastRow(), startRow);
  const vals = sheet.getRange(startRow, 1, last - startRow + 1, 1).getDisplayValues(); // A NO

  for (let i = 0; i < vals.length; i++) {
    if (normalizeNo_(vals[i][0]) === target) return startRow + i;
  }
  return 0;
}

function normalizeNo_(value) {
  return String(value || "")
    .replace(/[^\d]/g, "")
    .trim();
}

function parseLabeledInput_(text) {
  const cols = ["", "", "", "", "", "", "", "", "", "", ""];
  const fields = extractLabeledFields_(text, function (key) {
    return mapLabelToIndex_(key) !== -1;
  });
  let recognized = 0;

  for (let i = 0; i < fields.length; i++) {
    const item = fields[i] || {};
    const idx = mapLabelToIndex_(item.key);
    if (idx === -1) continue;
    cols[idx] = String(item.value || "").trim();
    recognized++;
  }

  const hasCore = cols.some(function (v) { return String(v || "").trim() !== ""; });
  return {
    matched: recognized >= 1 && Boolean(hasCore),
    cols: cols
  };
}

function normalizeLabelKey_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]/g, "");
}

function extractLabeledFields_(text, acceptKeyFn) {
  const raw = String(text || "")
    .replace(/\r\n/g, "\n")
    .replace(/\r/g, "\n");
  const accept = typeof acceptKeyFn === "function"
    ? acceptKeyFn
    : function () { return true; };
  const points = [];
  const colonRegex = /:/g;
  let m = null;
  let lastColon = -1;

  while ((m = colonRegex.exec(raw)) !== null) {
    const colonIndex = m.index;
    const beforeRaw = raw.slice(lastColon + 1, colonIndex);
    const words = [];
    const wordRegex = /[A-Za-z][A-Za-z-]*/g;
    let w = null;

    while ((w = wordRegex.exec(beforeRaw)) !== null) {
      words.push({
        word: String(w[0] || ""),
        index: Number(w.index || 0)
      });
    }

    const maxWords = Math.min(3, words.length);
    let resolved = null;

    for (let count = maxWords; count >= 1; count--) {
      const slice = words.slice(words.length - count);
      if (!slice.length) continue;
      const candidate = slice.map(function (item) { return item.word; }).join(" ");
      const key = normalizeLabelKey_(candidate);
      if (!key || !accept(key)) continue;

      resolved = {
        key: key,
        keyStart: (lastColon + 1) + slice[0].index
      };
      break;
    }

    if (resolved) {
      points.push({
        key: resolved.key,
        start: resolved.keyStart,
        valueStart: colonIndex + 1
      });
    }

    lastColon = colonIndex;
  }

  const fields = [];
  for (let i = 0; i < points.length; i++) {
    const nextStart = i + 1 < points.length ? points[i + 1].start : raw.length;
    const value = raw
      .slice(points[i].valueStart, nextStart)
      .replace(/\s*\n\s*/g, " ")
      .trim();

    fields.push({
      key: points[i].key,
      value: value
    });
  }

  return fields;
}

function mapLabelToIndex_(key) {
  if (key === "namamotor") return 0;
  if (key === "tahun") return 1;
  if (key === "plat") return 2;
  if (key === "suratsurat") return 3;
  if (key === "tahunplat") return 4;
  if (key === "pajak") return 5;
  if (key === "hargajual") return 6;
  if (key === "hargalaku") return 7;
  if (key === "hargabeli") return 8;
  if (key === "tglterjual" || key === "tanggalterjual") return 9;
  if (key === "status") return 10;
  return -1;
}

function parseLabeledUpdate_(text) {
  const cols = ["", "", "", "", ""];
  const fields = extractLabeledFields_(text, function (key) {
    return mapUpdateLabelToIndex_(key) !== -1;
  });
  let recognized = 0;

  for (let i = 0; i < fields.length; i++) {
    const item = fields[i] || {};
    const idx = mapUpdateLabelToIndex_(item.key);
    if (idx === -1) continue;
    cols[idx] = String(item.value || "").trim();
    recognized++;
  }

  const hasNo = Boolean(String(cols[0] || "").trim());
  const hasUpdateField = Boolean(
    String(cols[1] || "").trim() ||
    String(cols[2] || "").trim() ||
    String(cols[3] || "").trim() ||
    String(cols[4] || "").trim()
  );

  return {
    matched: recognized >= 2 && hasNo && hasUpdateField,
    cols: cols
  };
}

function mapUpdateLabelToIndex_(key) {
  if (key === "no" || key === "nomor") return 0;
  if (key === "hargajual") return 1;
  if (key === "hargalaku") return 2;
  if (key === "tglterjual" || key === "tanggalterjual") return 3;
  if (key === "status") return 4;
  return -1;
}

function isMotorMasukCommand_(text) {
  const normalized = String(text || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();
  if (!normalized) return false;

  if (normalized === "motor masuk") return true;
  if (/^(?:ada\s+)?motor\s+masuk(?:\s+.*)?$/.test(normalized)) return true;
  if (/^(?:mau|tolong|please|pls)\s+(?:input|isi|catat)?\s*motor\s+masuk(?:\s+.*)?$/.test(normalized)) {
    return true;
  }
  return false;
}

function handleMotorMasukSession_(session, text, lower, convoKey) {
  if (lower === "batal") {
    clearMotorMasukSession_(convoKey);
    return { reply: "Input motor masuk dibatalkan.", saveResult: null };
  }

  const stage = String((session && session.stage) || "").trim();

  if (stage === "awaiting_details") {
    const parsed = parseLabeledInput_(text);
    if (!parsed.matched) {
      return {
        reply: [
          "Format belum sesuai template motor masuk.",
          "Kirim ulang sesuai format berikut:",
          MOTOR_MASUK_TEMPLATE_TEXT,
          "",
          "Atau ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    const validation = validateInput_(parsed.cols);
    if (!validation.ok) {
      return { reply: "Format salah: " + validation.error, saveResult: null };
    }

    setMotorMasukSession_(convoKey, {
      stage: "awaiting_confirm",
      cols: validation.data
    });

    return {
      reply: [
        "Konfirmasi data motor masuk:",
        formatMotorMasukSummary_(validation.data),
        "",
        "Ketik OK untuk simpan / BATAL untuk batal"
      ].join("\n"),
      saveResult: null
    };
  }

  if (stage === "awaiting_confirm") {
    if (lower !== "ok") {
      return { reply: "Ketik OK untuk simpan / BATAL untuk batal", saveResult: null };
    }

    const saved = saveToSheet_((session && session.cols) || []);
    clearMotorMasukSession_(convoKey);
    return {
      reply: saved.ok
        ? "Data tersimpan di baris " + saved.row
        : "Gagal simpan: " + saved.error,
      saveResult: saved
    };
  }

  clearMotorMasukSession_(convoKey);
  return {
    reply: "Sesi motor masuk tidak valid. Ketik motor masuk untuk mulai ulang.",
    saveResult: null
  };
}

function formatMotorMasukSummary_(cols) {
  const list = Array.isArray(cols) ? cols : [];
  return [
    "NAMA MOTOR: " + displayCell_(list[0]),
    "TAHUN: " + displayCell_(list[1]),
    "PLAT: " + displayCell_(list[2]),
    "SURAT-SURAT: " + displayCell_(list[3]),
    "TAHUN PLAT: " + displayCell_(list[4]),
    "PAJAK: " + displayCell_(list[5]),
    "HARGA JUAL: " + displayCell_(list[6]),
    "HARGA BELI: " + displayCell_(list[8])
  ].join("\n");
}

function parseMotorLakuCommand_(text) {
  const raw = String(text || "").trim();
  if (!raw) return null;

  if (/^(?:ada\s+)?motor\s+laku$/i.test(raw)) {
    return { type: "ask_keyword", keyword: "" };
  }
  if (/^(?:ada\s+)?motor\s+terjual$/i.test(raw)) {
    return { type: "ask_keyword", keyword: "" };
  }

  let m = raw.match(/^motor\s+(.+?)\s+laku$/i);
  if (m) return { type: "keyword", keyword: String(m[1] || "").trim() };

  m = raw.match(/^motor\s+laku\s+(.+)$/i);
  if (m) return { type: "keyword", keyword: String(m[1] || "").trim() };

  m = raw.match(/^motor\s+terjual\s+(.+)$/i);
  if (m) return { type: "keyword", keyword: String(m[1] || "").trim() };

  m = raw.match(/^motor\s+(.+?)\s+terjual$/i);
  if (m) return { type: "keyword", keyword: String(m[1] || "").trim() };

  return null;
}

function parseMotorLakuKeywordReply_(text) {
  const raw = String(text || "").trim();
  if (!raw) return "";
  if (/^(ok|batal|menu|halo|hi)$/i.test(raw)) return "";

  const m = raw.match(/^motor\s+(.+)$/i);
  if (m) return String(m[1] || "").trim();
  return raw;
}

function findActiveMotorRowsByKeyword_(keyword) {
  const q = normalizeText_(keyword);
  if (!q) return [];

  const ss = getSpreadsheet_();
  if (!ss) return [];

  const sh = ss.getSheetByName(SHEET_NAME);
  if (!sh) return [];

  const startRow = 2;
  const last = sh.getLastRow();
  if (last < startRow) return [];

  const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
  const displayVals = range.getDisplayValues();
  const rawVals = range.getValues();
  const rows = [];

  for (let i = 0; i < displayVals.length; i++) {
    const row = displayVals[i];
    const rawRow = rawVals[i];
    const nama = normalizeText_(row[1]);
    if (!nama || nama.indexOf(q) === -1) continue;
    if (isSoldStatusValue_(rawRow, row)) continue;

    const no = String(row[0] || "").replace(/[^\d]/g, "").trim();
    if (!no) continue;

    rows.push({
      no: no,
      nama: String(row[1] || "").trim(),
      tahun: String(row[2] || "").trim() || "-",
      plat: String(row[3] || "").trim() || "-"
    });
  }

  return rows;
}

function findAllMotorRowsByKeyword_(keyword) {
  const q = normalizeText_(keyword);
  if (!q) return [];

  const ss = getSpreadsheet_();
  if (!ss) return [];

  const sh = ss.getSheetByName(SHEET_NAME);
  if (!sh) return [];

  const startRow = 2;
  const last = sh.getLastRow();
  if (last < startRow) return [];

  const range = sh.getRange(startRow, 1, last - startRow + 1, 13);
  const displayVals = range.getDisplayValues();
  const rawVals = range.getValues();
  const rows = [];

  for (let i = 0; i < displayVals.length; i++) {
    const row = displayVals[i];
    const rawRow = rawVals[i];
    const nama = normalizeText_(row[1]);
    if (!nama || nama.indexOf(q) === -1) continue;

    const no = String(row[0] || "").replace(/[^\d]/g, "").trim();
    if (!no) continue;

    rows.push({
      row: startRow + i,
      no: no,
      nama: String(row[1] || "").trim(),
      tahun: String(row[2] || "").trim() || "-",
      plat: String(row[3] || "").trim() || "-",
      suratSurat: String(row[4] || "").trim(),
      tahunPlat: String(row[5] || "").trim(),
      pajak: String(row[6] || "").trim(),
      hargaJual: String(row[7] || "").trim(),
      hargaLaku: String(row[8] || "").trim(),
      tglTerjual: String(row[9] || "").trim(),
      hargaBeli: String(row[11] || "").trim(),
      status: String(row[12] || "").trim(),
      isSold: isSoldStatusValue_(rawRow, row)
    });
  }

  return rows;
}

function formatEditDataMotorOptionsReply_(keyword, options, totalFound) {
  const list = Array.isArray(options) ? options : [];
  const total = Number(totalFound || 0);
  const lines = [
    'Ditemukan ' + total + ' data motor "' + keyword + '".',
    "Motor yang mana? Pilih dari daftar berikut:"
  ];

  for (let i = 0; i < list.length; i++) {
    const item = list[i] || {};
    const tahun = item.tahun && item.tahun !== "-" ? " " + item.tahun : "";
    const soldTag = item.isSold ? "TERJUAL" : "AKTIF";
    lines.push(
      (i + 1) +
      ". NO: " + displayCell_(item.no) +
      " - " + displayCell_(item.nama) + tahun +
      " - Plat " + displayCell_(item.plat) +
      " - " + soldTag
    );
  }

  if (total > list.length) {
    lines.push("");
    lines.push(
      "Daftar dipotong ke " + list.length +
      " baris pertama dari total " + total + " data."
    );
  }

  lines.push("");
  lines.push("Balas: nomor <urutan> (contoh: nomor 1)");
  lines.push("Atau: pilih <urutan> / no <no> / <angka>");
  lines.push("Ketik BATAL untuk batal.");
  return lines.join("\n");
}

function formatMotorLakuOptionsReply_(keyword, options, totalFound) {
  const list = Array.isArray(options) ? options : [];
  const total = Number(totalFound || 0);
  const lines = [
    'Ditemukan ' + total + ' data motor "' + keyword + '".',
    "Pilih motor yang terjual:"
  ];

  for (let i = 0; i < list.length; i++) {
    const item = list[i] || {};
    const tahun = item.tahun && item.tahun !== "-" ? " " + item.tahun : "";
    lines.push(
      (i + 1) +
      ". NO: " + displayCell_(item.no) +
      " - " + displayCell_(item.nama) + tahun +
      " - Plat " + displayCell_(item.plat)
    );
  }

  if (total > list.length) {
    lines.push("");
    lines.push(
      "Daftar dipotong ke " + list.length +
      " baris pertama dari total " + total + " data."
    );
  }

  lines.push("");
  lines.push("Balas: no <pilihan> laku <harga>");
  lines.push("Atau singkat: <pilihan> <harga> (format singkat)");
  lines.push("Jika ingin pakai urutan list: pilih <urutan> laku <harga>");
  lines.push("Contoh: no 2 laku 7000000");
  lines.push("Contoh singkat: 2 7000000");
  lines.push("Contoh urutan list: pilih 2 laku 7000000");
  lines.push("Ketik BATAL untuk batal.");
  return lines.join("\n");
}

function findSelectionOptionByNo_(rawSelection, options) {
  const list = Array.isArray(options) ? options : [];
  if (!rawSelection || rawSelection < 1) return null;

  for (let i = 0; i < list.length; i++) {
    if (String(list[i].no || "").trim() === String(rawSelection)) {
      return list[i];
    }
  }

  return null;
}

function findSelectionOptionByIndex_(rawSelection, options) {
  const list = Array.isArray(options) ? options : [];
  if (!rawSelection || rawSelection < 1) return null;
  if (rawSelection <= list.length) return list[rawSelection - 1];
  return null;
}

function resolveSelectionOption_(rawSelection, options, mode) {
  const pickMode = String(mode || "auto").trim().toLowerCase();
  if (pickMode === "no") {
    return findSelectionOptionByNo_(rawSelection, options);
  }
  if (pickMode === "index") {
    return findSelectionOptionByIndex_(rawSelection, options);
  }
  const byNo = findSelectionOptionByNo_(rawSelection, options);
  if (byNo) return byNo;
  const byIndex = findSelectionOptionByIndex_(rawSelection, options);
  if (byIndex) return byIndex;
  return null;
}

function normalizeMotorLakuPrice_(value) {
  const raw = String(value || "").trim();
  if (!raw) return "";
  const parsed = parseNumber_(raw);
  if (typeof parsed !== "number" || !isFinite(parsed) || parsed <= 0) return "";
  if (Math.round(parsed) !== parsed) return String(parsed);
  return String(Math.trunc(parsed));
}

function parseMotorLakuSelection_(text, options) {
  const raw = String(text || "").trim();
  let mode = "auto";
  let m = raw.match(/^pilih\s+(\d+)\s+laku\s+(.+)$/i);
  if (m) {
    mode = "index";
  }
  if (!m) {
    m = raw.match(/^pilih\s+(\d+)\s+(.+)$/i);
    if (m) mode = "index";
  }
  if (!m) {
    m = raw.match(/^no\s+(\d+)\s+laku\s+(.+)$/i);
    if (m) mode = "no";
  }
  if (!m) {
    m = raw.match(/^no\s+(\d+)\s+(.+)$/i);
    if (m) mode = "no";
  }
  if (!m) {
    m = raw.match(/^(\d+)\s+(.+)$/);
    if (m) mode = "auto";
  }
  if (!m) {
    return { ok: false, error: "Format pilihan tidak sesuai." };
  }

  const rawSelection = Number(m[1]);
  if (!rawSelection || rawSelection < 1) {
    return { ok: false, error: "Nomor pilihan tidak valid." };
  }

  const hargaLaku = normalizeMotorLakuPrice_(m[2]);
  if (!hargaLaku) {
    return { ok: false, error: "Harga laku tidak valid." };
  }

  const chosen = resolveSelectionOption_(rawSelection, options, mode);
  if (!chosen) {
    return { ok: false, error: "Pilihan tidak ditemukan di daftar." };
  }

  return {
    ok: true,
    option: chosen,
    hargaLaku: hargaLaku
  };
}

function handleMotorLakuSession_(session, text, lower, convoKey) {
  if (lower === "batal") {
    clearMotorLakuSession_(convoKey);
    return { reply: "Proses motor laku dibatalkan.", saveResult: null };
  }

  const stage = String((session && session.stage) || "").trim();

  if (stage === "awaiting_keyword") {
    const command = parseMotorLakuCommand_(text);
    if (command && command.type === "ask_keyword") {
      return { reply: "Motor apa?", saveResult: null };
    }

    const keyword = command && command.type === "keyword"
      ? String(command.keyword || "").trim()
      : parseMotorLakuKeywordReply_(text);
    if (!keyword) {
      return {
        reply: [
          "Motor apa?",
          "Balas dengan nama motor. Contoh: beat atau motor beat.",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    const options = findActiveMotorRowsByKeyword_(keyword);
    if (!options.length) {
      return {
        reply: 'Data motor "' + keyword + '" tidak ditemukan. Coba nama lain atau ketik BATAL.',
        saveResult: null
      };
    }

    const shownOptions = options.slice(0, MOTOR_LAKU_LIST_MAX);
    setMotorLakuSession_(convoKey, {
      stage: "awaiting_selection",
      keyword: keyword,
      options: shownOptions
    });

    return {
      reply: formatMotorLakuOptionsReply_(keyword, shownOptions, options.length),
      saveResult: null
    };
  }

  if (stage === "awaiting_selection") {
    const parsed = parseMotorLakuSelection_(text, session.options);
    if (!parsed.ok) {
      return {
        reply: [
          parsed.error || "Format salah.",
          "Gunakan format: no <pilihan> laku <harga>",
          "Atau format singkat: <pilihan> <harga>",
          "Jika mau pakai urutan list: pilih <urutan> laku <harga>",
          "Contoh: no 2 laku 7000000",
          "Contoh singkat: 2 7000000",
          "Contoh urutan list: pilih 2 laku 7000000",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    setMotorLakuSession_(convoKey, {
      stage: "awaiting_confirm",
      selected: parsed.option,
      hargaLaku: parsed.hargaLaku
    });

    return {
      reply:
        "NO " + parsed.option.no +
        " akan ditandai terjual harga " + parsed.hargaLaku +
        ". OK / BATAL",
      saveResult: null
    };
  }

  if (stage === "awaiting_confirm") {
    if (lower !== "ok") {
      return { reply: "Ketik OK untuk simpan / BATAL untuk batal", saveResult: null };
    }

    const cols = [
      String((session.selected && session.selected.no) || "").trim(),
      "",
      String(session.hargaLaku || "").trim(),
      "",
      "terjual"
    ];
    const updated = updateSoldData_(cols);
    clearMotorLakuSession_(convoKey);
    return {
      reply: updated.ok
        ? "Data terupdate di baris " + updated.row
        : "Gagal update: " + updated.error,
      saveResult: updated
    };
  }

  clearMotorLakuSession_(convoKey);
  return {
    reply: "Sesi motor laku tidak valid. Ketik motor <nama> laku untuk mulai ulang.",
    saveResult: null
  };
}

function parseEditDataMotorCommand_(text) {
  const raw = String(text || "").trim();
  if (!raw) return null;

  if (/^edit\s+data\s+motor$/i.test(raw)) {
    return { type: "ask_keyword", keyword: "" };
  }

  const m = raw.match(/^edit\s+data\s+motor\s+(.+)$/i);
  if (!m) return null;
  return { type: "keyword", keyword: String(m[1] || "").trim() };
}

function parseEditDataMotorKeywordReply_(text) {
  const raw = String(text || "").trim();
  if (!raw) return "";
  if (/^(ok|batal|menu|halo|hi)$/i.test(raw)) return "";

  const m = raw.match(/^motor\s+(.+)$/i);
  if (m) return String(m[1] || "").trim();
  return raw;
}

function parseEditDataMotorSelection_(text, options) {
  const raw = String(text || "").trim().replace(/[.]+$/, "");
  let mode = "auto";
  let m = raw.match(/^nomor\s+(\d+)$/i);
  if (m) mode = "index";

  if (!m) {
    m = raw.match(/^pilih\s+(\d+)$/i);
    if (m) mode = "index";
  }

  if (!m) {
    m = raw.match(/^no\s+(\d+)$/i);
    if (m) mode = "no";
  }

  if (!m) {
    m = raw.match(/^(\d+)$/);
    if (m) mode = "auto";
  }

  if (!m) {
    return { ok: false, error: "Format pilihan tidak sesuai." };
  }

  const rawSelection = Number(m[1]);
  if (!rawSelection || rawSelection < 1) {
    return { ok: false, error: "Nomor pilihan tidak valid." };
  }

  const chosen = resolveSelectionOption_(rawSelection, options, mode);
  if (!chosen) {
    return { ok: false, error: "Pilihan tidak ditemukan di daftar." };
  }

  return {
    ok: true,
    option: chosen
  };
}

function parseEditDataMotorTemplate_(text) {
  const cols = ["", "", "", "", "", "", "", "", "", "", ""];
  const fields = extractLabeledFields_(text, function (key) {
    return key === "no" || key === "nomor" || mapLabelToIndex_(key) !== -1;
  });
  let no = "";
  let recognized = 0;

  for (let i = 0; i < fields.length; i++) {
    const item = fields[i] || {};
    const key = item.key;
    const value = String(item.value || "").trim();

    if (key === "no" || key === "nomor") {
      no = normalizeNo_(value);
      recognized++;
      continue;
    }

    const idx = mapLabelToIndex_(key);
    if (idx === -1) continue;
    cols[idx] = value;
    recognized++;
  }

  const hasEditableValue = cols.some(function (v) {
    return String(v || "").trim() !== "";
  });

  if (!recognized || !hasEditableValue) {
    return { ok: false, error: "Format edit data belum sesuai template." };
  }

  const validation = validateInput_(cols);
  if (!validation.ok) {
    return { ok: false, error: validation.error };
  }

  return {
    ok: true,
    no: no,
    cols: validation.data
  };
}

function hasInputValue_(value) {
  return String(value || "").trim() !== "";
}

function buildEditDataMotorMergedCols_(selected, inputCols) {
  const src = selected || {};
  const incoming = Array.isArray(inputCols) ? inputCols : [];
  const current = [
    String(src.nama || "").trim(),
    String(src.tahun || "").trim(),
    String(src.plat || "").trim(),
    String(src.suratSurat || "").trim(),
    String(src.tahunPlat || "").trim(),
    String(src.pajak || "").trim(),
    String(src.hargaJual || "").trim(),
    "",
    String(src.hargaBeli || "").trim(),
    "",
    ""
  ];

  const out = current.slice();
  for (let i = 0; i < out.length; i++) {
    if (hasInputValue_(incoming[i])) {
      out[i] = String(incoming[i] || "").trim();
    }
  }
  return out;
}

function formatEditCurrencyCell_(value) {
  const raw = String(value || "").trim();
  if (!raw) return "-";
  if (/^rp/i.test(raw)) return raw;

  const parsed = parseNumber_(raw);
  if (typeof parsed === "number" && isFinite(parsed)) {
    return "Rp" + formatRupiah_(parsed);
  }
  return raw;
}

function buildEditDataMotorTemplateReply_(selected) {
  const item = selected || {};
  return [
    "NO: " + displayCell_(item.no),
    "NAMA MOTOR: " + displayCell_(item.nama),
    "TAHUN: " + displayCell_(item.tahun),
    "PLAT: " + displayCell_(item.plat),
    "SURAT-SURAT: " + displayCell_(item.suratSurat),
    "TAHUN PLAT: " + displayCell_(item.tahunPlat),
    "PAJAK: " + displayCell_(item.pajak),
    "HARGA JUAL: " + formatEditCurrencyCell_(item.hargaJual),
    "HARGA BELI: " + formatEditCurrencyCell_(item.hargaBeli),
    "SILAKAN DIEDIT.."
  ].join("\n");
}

function formatEditDataMotorSummary_(no, cols) {
  const list = Array.isArray(cols) ? cols : [];
  return [
    "NO: " + displayCell_(no),
    "NAMA MOTOR: " + displayCell_(list[0]),
    "TAHUN: " + displayCell_(list[1]),
    "PLAT: " + displayCell_(list[2]),
    "SURAT-SURAT: " + displayCell_(list[3]),
    "TAHUN PLAT: " + displayCell_(list[4]),
    "PAJAK: " + displayCell_(list[5]),
    "HARGA JUAL: " + formatEditCurrencyCell_(list[6]),
    "HARGA BELI: " + formatEditCurrencyCell_(list[8])
  ].join("\n");
}

function handleEditDataMotorSession_(session, text, lower, convoKey) {
  if (lower === "batal") {
    clearEditDataMotorSession_(convoKey);
    return { reply: "Proses edit data motor dibatalkan.", saveResult: null };
  }

  const stage = String((session && session.stage) || "").trim();

  if (stage === "awaiting_keyword") {
    const command = parseEditDataMotorCommand_(text);
    if (command && command.type === "ask_keyword") {
      return { reply: "Motor apa?", saveResult: null };
    }

    const keyword = command && command.type === "keyword"
      ? String(command.keyword || "").trim()
      : parseEditDataMotorKeywordReply_(text);

    if (!keyword) {
      return {
        reply: [
          "Motor apa?",
          "Balas dengan nama motor. Contoh: shogun atau motor shogun.",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    const options = findAllMotorRowsByKeyword_(keyword);
    if (!options.length) {
      return {
        reply: 'Data motor "' + keyword + '" tidak ditemukan. Coba nama lain atau ketik BATAL.',
        saveResult: null
      };
    }

    const shownOptions = options.slice(0, MOTOR_LAKU_LIST_MAX);
    setEditDataMotorSession_(convoKey, {
      stage: "awaiting_selection",
      keyword: keyword,
      options: shownOptions
    });

    return {
      reply: formatEditDataMotorOptionsReply_(keyword, shownOptions, options.length),
      saveResult: null
    };
  }

  if (stage === "awaiting_selection") {
    const parsed = parseEditDataMotorSelection_(text, session.options);
    if (!parsed.ok) {
      return {
        reply: [
          parsed.error || "Format pilihan tidak sesuai.",
          "Balas: nomor <urutan> (contoh: nomor 1)",
          "Atau: pilih <urutan> / no <no> / <angka>",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    setEditDataMotorSession_(convoKey, {
      stage: "awaiting_details",
      selected: parsed.option
    });

    return {
      reply: [
        buildEditDataMotorTemplateReply_(parsed.option),
        "",
        "Kirim ulang template di atas setelah diedit.",
        "Setelah itu bot akan minta konfirmasi OK / BATAL."
      ].join("\n"),
      saveResult: null
    };
  }

  if (stage === "awaiting_details") {
    const parsed = parseEditDataMotorTemplate_(text);
    if (!parsed.ok) {
      return {
        reply: [
          parsed.error || "Format edit data belum sesuai.",
          "Kirim ulang sesuai template berikut:",
          buildEditDataMotorTemplateReply_(session.selected || {}),
          "",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    const selectedNo = normalizeNo_((session.selected && session.selected.no) || "");
    if (parsed.no && selectedNo && parsed.no !== selectedNo) {
      return {
        reply: "NO pada template tidak sesuai dengan data terpilih. Gunakan NO: " + selectedNo,
        saveResult: null
      };
    }

    const mergedCols = buildEditDataMotorMergedCols_(session.selected, parsed.cols);
    const validation = validateInput_(mergedCols);
    if (!validation.ok) {
      return { reply: "Format salah: " + validation.error, saveResult: null };
    }

    setEditDataMotorSession_(convoKey, {
      stage: "awaiting_confirm",
      selected: session.selected,
      cols: validation.data
    });

    return {
      reply: [
        "Konfirmasi edit data motor:",
        formatEditDataMotorSummary_(selectedNo, validation.data),
        "",
        "Ketik OK untuk simpan / BATAL untuk batal"
      ].join("\n"),
      saveResult: null
    };
  }

  if (stage === "awaiting_confirm") {
    if (lower !== "ok") {
      return { reply: "Ketik OK untuk simpan / BATAL untuk batal", saveResult: null };
    }

    const selectedNo = normalizeNo_((session.selected && session.selected.no) || "");
    const updated = updateMotorDataByNo_(selectedNo, (session && session.cols) || []);
    clearEditDataMotorSession_(convoKey);
    return {
      reply: updated.ok
        ? "Data motor terupdate di baris " + updated.row
        : "Gagal update data motor: " + updated.error,
      saveResult: updated
    };
  }

  clearEditDataMotorSession_(convoKey);
  return {
    reply: "Sesi edit data motor tidak valid. Ketik edit data motor <nama> untuk mulai ulang.",
    saveResult: null
  };
}

function parseEditHargaJualByNameCommand_(text) {
  const raw = String(text || "").trim();
  if (!raw) return null;

  let m = raw.match(/^edit\s+harga\s+jual\s+motor(?:\s+(.+))?$/i);
  if (!m) {
    m = raw.match(/^edit\s+harga\s+jual(?:\s+(.+))?$/i);
  }
  if (!m) return null;
  return m[1] ? String(m[1]).trim() : "";
}

function formatEditHargaJualOptionsReply_(keyword, options, totalFound) {
  const list = Array.isArray(options) ? options : [];
  const total = Number(totalFound || 0);
  const lines = [
    'Ditemukan ' + total + ' data motor "' + keyword + '" (belum terjual).',
    "Pilih motor untuk edit harga jual:"
  ];

  for (let i = 0; i < list.length; i++) {
    const item = list[i] || {};
    const tahun = item.tahun && item.tahun !== "-" ? " " + item.tahun : "";
    lines.push(
      (i + 1) +
      ". NO: " + displayCell_(item.no) +
      " - " + displayCell_(item.nama) + tahun +
      " - Plat " + displayCell_(item.plat)
    );
  }

  if (total > list.length) {
    lines.push("");
    lines.push(
      "Daftar dipotong ke " + list.length +
      " baris pertama dari total " + total + " data."
    );
  }

  lines.push("");
  lines.push("Balas berdasarkan NO motor: no <no> <harga>");
  lines.push("Atau singkat (otomatis NO dulu): <no> <harga>");
  lines.push("Jika ingin berdasarkan urutan list: pilih <urutan> <harga>");
  lines.push("Contoh: no 7 23500000");
  lines.push("Contoh singkat: 7 23500000");
  lines.push("Contoh urutan list: pilih 2 23500000");
  lines.push("Ketik BATAL untuk batal.");
  return lines.join("\n");
}

function parseEditHargaJualSelection_(text, options) {
  const raw = String(text || "").trim();
  let mode = "auto";
  let m = raw.match(/^pilih\s+(\d+)\s+(.+)$/i);
  if (m) {
    mode = "index";
  }
  if (!m) {
    m = raw.match(/^no\s+(\d+)\s+(.+)$/i);
    if (m) mode = "no";
  }
  if (!m) {
    m = raw.match(/^(\d+)\s+(.+)$/);
    if (m) mode = "auto";
  }
  if (!m) {
    return { ok: false, error: "Format pilihan tidak sesuai." };
  }

  const rawSelection = Number(m[1]);
  if (!rawSelection || rawSelection < 1) {
    return { ok: false, error: "Nomor pilihan tidak valid." };
  }

  const hargaJual = normalizeMotorLakuPrice_(m[2]);
  if (!hargaJual) {
    return { ok: false, error: "Harga jual tidak valid." };
  }

  const chosen = resolveSelectionOption_(rawSelection, options, mode);
  if (!chosen) {
    return { ok: false, error: "Pilihan tidak ditemukan di daftar." };
  }

  return {
    ok: true,
    option: chosen,
    hargaJual: hargaJual
  };
}

function handleEditHargaJualSession_(session, text, lower, convoKey) {
  if (lower === "batal") {
    clearEditHargaJualSession_(convoKey);
    return { reply: "Proses edit harga jual dibatalkan.", saveResult: null };
  }

  const stage = String((session && session.stage) || "").trim();

  if (stage === "awaiting_selection") {
    const parsed = parseEditHargaJualSelection_(text, session.options);
    if (!parsed.ok) {
      return {
        reply: [
          parsed.error || "Format pilihan tidak sesuai.",
          "Gunakan format NO motor: no <no> <harga>",
          "Atau format singkat (otomatis NO dulu): <no> <harga>",
          "Jika mau urutan list: pilih <urutan> <harga>",
          "Contoh: no 7 23500000",
          "Contoh singkat: 7 23500000",
          "Contoh urutan list: pilih 2 23500000",
          "Ketik BATAL untuk membatalkan."
        ].join("\n"),
        saveResult: null
      };
    }

    const updated = updateSoldData_([
      String((parsed.option && parsed.option.no) || "").trim(),
      parsed.hargaJual,
      "",
      "",
      ""
    ]);
    clearEditHargaJualSession_(convoKey);
    return {
      reply: updated.ok
        ? "Harga jual terupdate di baris " + updated.row
        : "Gagal update: " + updated.error,
      saveResult: updated
    };
  }

  clearEditHargaJualSession_(convoKey);
  return {
    reply: "Sesi edit harga jual tidak valid. Ketik edit harga jual motor <nama> untuk mulai ulang.",
    saveResult: null
  };
}

function isDailyExpensePromptCommand_(text) {
  const normalized = String(text || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();

  return (
    normalized === "pengeluaran" ||
    normalized === "pengeluaran hari ini" ||
    normalized === "trigger pengeluaran harian" ||
    normalized === "pengeluaran harian" ||
    normalized === "input pengeluaran harian" ||
    normalized === "isi pengeluaran harian"
  );
}

function parseDailyExpenseTemplate_(text) {
  const fields = extractLabeledFields_(text, function (key) {
    return (
      key === "keterangan" ||
      key === "ket" ||
      key === "totalpengeluaran" ||
      key === "pengeluaran" ||
      key === "total" ||
      key === "nominal" ||
      key === "jumlah"
    );
  });
  let keterangan = "";
  let total = "";

  for (let i = 0; i < fields.length; i++) {
    const item = fields[i] || {};
    const key = normalizeExpenseKey_(item.key);
    const value = String(item.value || "").trim();
    if (!value) continue;

    if (key === "keterangan" || key === "ket") {
      keterangan = value.replace(/\s*[-–—]+\s*$/, "").trim();
      continue;
    }
    if (
      key === "totalpengeluaran" ||
      key === "pengeluaran" ||
      key === "total" ||
      key === "nominal" ||
      key === "jumlah"
    ) {
      total = value;
    }
  }

  if (!keterangan) {
    return { ok: false, error: "Keterangan wajib diisi." };
  }

  const parsedTotal = normalizeMotorLakuPrice_(total);
  if (!parsedTotal) {
    return { ok: false, error: "Total pengeluaran tidak valid." };
  }

  return {
    ok: true,
    keterangan: keterangan,
    totalPengeluaran: parsedTotal
  };
}

function normalizeExpenseKey_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]/g, "")
    .trim();
}

function buildDailyExpenseSaveCommand_(keterangan, totalPengeluaran) {
  const safeKet = String(keterangan || "").replace(/;/g, ",").trim();
  const safeTotal = String(totalPengeluaran || "").trim();
  return "pengeluaran#" + safeKet + ";" + safeTotal;
}

function handleDailyExpenseSession_(session, text, lower, convoKey) {
  if (lower === "batal") {
    clearDailyExpenseSession_(convoKey);
    return { reply: "Input pengeluaran harian dibatalkan.", saveResult: null };
  }

  const parsed = parseDailyExpenseTemplate_(text);
  if (!parsed.ok) {
    return {
      reply: [
        parsed.error || "Format pengeluaran belum sesuai.",
        "Gunakan format:",
        "- keterangan :",
        "- total pengeluaran :",
        "Contoh:",
        "- keterangan : beli bensin, parkir",
        "- total pengeluaran : 350000",
        "Ketik BATAL untuk membatalkan."
      ].join("\n"),
      saveResult: null
    };
  }

  const command = buildDailyExpenseSaveCommand_(parsed.keterangan, parsed.totalPengeluaran);
  const body = command.slice("pengeluaran#".length).trim();
  const cols = body.split(";").map(function (s) { return s.trim(); });
  const saved = saveDailyExpenseData_(cols);
  clearDailyExpenseSession_(convoKey);

  return {
    reply: saved.ok
      ? "Pengeluaran harian tersimpan di baris " + saved.row
      : "Gagal simpan pengeluaran: " + saved.error,
    saveResult: saved
  };
}

function buildConversationKey_(sender, chatJid) {
  const s = normalizeWaIdentity_(sender);
  const c = normalizeWaIdentity_(chatJid);
  return (s || "-") + "|" + (c || "-");
}

function getMotorMasukSession_(convoKey) {
  const key = motorMasukSessionCacheKey_(convoKey);
  return getSessionObject_(key);
}

function setMotorMasukSession_(convoKey, value) {
  const key = motorMasukSessionCacheKey_(convoKey);
  if (!key) return;

  const payload = value && typeof value === "object" ? value : {};
  payload.createdAt = Date.now();

  setSessionObject_(key, payload, MOTOR_MASUK_SESSION_TTL_SECONDS);
}

function clearMotorMasukSession_(convoKey) {
  const key = motorMasukSessionCacheKey_(convoKey);
  clearSessionObject_(key);
}

