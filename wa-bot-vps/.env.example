PORT=3000

# Fokus utama: bot sendiri
# BAILEYS = bot WA sendiri (scan QR)
# WEBHOOK = opsional jika mau pakai Fonnte
BOT_MODE=BAILEYS

# Wajib: endpoint Web App Apps Script
APPS_SCRIPT_WEBHOOK_URL=
APPS_SCRIPT_TIMEOUT_MS=15000
APPS_SCRIPT_INTERNAL_API_KEY=

# Nomor bot WA (tanpa +)
BOT_NUMBER=201507007785

# Untuk mode BAILEYS
WA_SESSION_DIR=./auth_info_baileys
ALLOW_GROUP_MESSAGES=false
ALLOW_SELF_CHAT_MESSAGES=true
DEBUG_WA_FILTER=false
DAILY_EXPENSE_REMINDER_ENABLED=true
DAILY_EXPENSE_REMINDER_TIME=23:00
DAILY_EXPENSE_REMINDER_TZ=Asia/Jakarta
HEALTH_SERVER_ENABLED=true
HEALTH_SERVER_HOST=127.0.0.1
HEALTH_SERVER_PORT=3100
APPSCRIPT_MONITOR_ENABLED=true
APPSCRIPT_MONITOR_INTERVAL_SEC=180
APPSCRIPT_MONITOR_FAILURE_THRESHOLD=3
APPSCRIPT_MONITOR_ALERT_COOLDOWN_SEC=900
APPSCRIPT_MONITOR_EXIT_ON_FAILURE=false

# AI-First brain (WAJIB)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=15000
AI_TEXT_MIN_CONFIDENCE=0.75
AI_TEXT_DEBUG=false

# Agent mode memory + scheduler
AGENT_MEMORY_FILE=./runtime/agent-memory.json
AGENT_MEMORY_MAX_REMINDERS=5000
AGENT_SCHEDULER_ENABLED=true
AGENT_SCHEDULER_POLL_SEC=20
AGENT_SCHEDULER_BATCH=10
AGENT_DEBUG=false

# Untuk mode WEBHOOK (opsional)
FONNTE_TOKEN=
