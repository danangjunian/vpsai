PORT=3000

# Fokus utama: bot sendiri
# BAILEYS = bot WA sendiri (scan QR)
# WEBHOOK = opsional jika mau pakai Fonnte
BOT_MODE=BAILEYS

# Wajib: endpoint Web App Apps Script
APPS_SCRIPT_WEBHOOK_URL=
APPS_SCRIPT_TIMEOUT_MS=15000

# Untuk mode BAILEYS
WA_SESSION_DIR=./auth_info_baileys
ALLOW_GROUP_MESSAGES=false

# Untuk mode WEBHOOK (opsional)
FONNTE_TOKEN=
